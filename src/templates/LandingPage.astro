          </svg>
          <div class="mt-3 flex flex-wrap items-center justify-center gap-x-2 gap-y-1 text-center font-mono text-[8px] uppercase tracking-[0.18em] text-slate-500 sm:flex-nowrap sm:justify-between sm:text-[9px] sm:tracking-[0.3em]">
