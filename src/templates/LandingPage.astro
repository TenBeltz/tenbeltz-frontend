    <Banner
      title={content.banner.title}
      paragraph={content.banner.paragraph}
      buttonText={content.banner.button}
      buttonHref="#contact-section"
    />

    <section class="relative text-white">
      <div class="max-w-screen-xl px-4 py-14 mx-auto lg:px-16 lg:py-16">
        <ScrollReveal client:visible>
          <a
            href={whoBehindHref}
            class="group flex flex-col items-start gap-5 rounded-2xl border border-pheromone-purple/25 bg-[#0B0122CC]/80 px-6 py-6 shadow-[0_0_25px_rgba(3,7,18,0.35)] backdrop-blur-sm transition-all hover:border-pheromone-purple/60 hover:bg-[#130130CC]/80 sm:flex-row sm:items-center sm:gap-6"
          >
            <span class="relative flex-shrink-0">
              <span aria-hidden="true" class="absolute inset-0 -m-1 rounded-full bg-gradient-to-br from-pheromone-light/50 via-pheromone-purple/30 to-transparent blur-md"></span>
              <span class="relative block rounded-full p-[2px] bg-gradient-to-br from-pheromone-light via-pheromone-purple to-sapphire-siren">
                <img
                  src="/images/team/aritz.webp"
                  alt="Aritz Jaber Lopes"
