              <span class="inline-block h-1.5 w-1.5 rounded-full bg-cold-heights shadow-[0_0_8px_rgba(121,202,255,0.6)]"></span>
              {lang === 'en' ? 'operable system' : 'sistema operable'}
            </div>
            <div class="flex items-center gap-1.5 font-mono text-[9px] text-slate-500">
              <span class="inline-block h-1 w-1 rounded-full bg-slate-600"></span>
              <span class="inline-block h-1 w-1 rounded-full bg-slate-600"></span>
              <span class="inline-block h-1 w-1 rounded-full bg-slate-600"></span>
