---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// This template serves both locales, so the canonical must be locale-aware. A hardcoded
// Spanish URL told Google the English page was a duplicate and kept it out of the index.
const canonical = `https://tenbeltz.com${lang === 'en' ? '/en' : ''}/politicas`;
---

<Layout
  title={t('policies.title')}
  description={t('policies.description')}
  canonical={canonical}
>
  <Header />
  <main class="relative z-10 flex flex-col flex-1 overflow-x-hidden">
    <section class="relative text-white bg-grid">
      <div class="pointer-events-none absolute -top-16 left-10 h-64 w-64 rounded-full bg-pheromone-purple/20 blur-3xl"></div>
      <div class="mx-auto flex w-full max-w-screen-lg flex-col gap-10 px-4 py-20 lg:px-12 lg:py-24">
        <div class="flex flex-col gap-4">
          <span class="text-xs font-semibold tracking-[0.4em] text-pheromone-purple/70">{t('policies.tag')}</span>
          <h1 class="text-4xl font-extrabold lg:text-5xl">{t('policies.h1')}</h1>
          <p class="text-base text-slate-300">
            {t('policies.intro')}
          </p>
          <p class="text-sm text-slate-400">
            <span class="font-semibold text-white">{t('policies.updated.label')}</span>
            {' '}{t('policies.updated.date')}
          </p>
        </div>

        <div class="grid gap-6">
          <section class="rounded-2xl border border-pheromone-purple/20 bg-[#0B0122CC]/80 px-6 py-6">
            <h2 class="text-xl font-semibold">{t('policies.legal.title')}</h2>
            <ul class="mt-3 space-y-2 text-sm text-slate-300">
              <li>
                <span class="font-semibold text-white">{t('policies.legal.owner.label')}</span>
                {' '}{t('policies.legal.owner.text')}
              </li>
              <li>
                <span class="font-semibold text-white">{t('policies.legal.cif.label')}</span>
                {' '}{t('policies.legal.cif.text')}
              </li>
              <li>
                <span class="font-semibold text-white">{t('policies.legal.address.label')}</span>
                {' '}{t('policies.legal.address.text')}
              </li>
              <li>
                <span class="font-semibold text-white">{t('policies.legal.domain.label')}</span>
                {' '}{t('policies.legal.domain.text')}
              </li>
              <li>
                <span class="font-semibold text-white">{t('policies.legal.phone.label')}</span>
                {' '}{t('policies.legal.phone.text')}
              </li>
              <li>
                <span class="font-semibold text-white">{t('policies.legal.contact.label')}</span>
                <a
                  href="mailto:hello@tenbeltz.com"
                  class="ml-1 text-pheromone-purple underline underline-offset-2 hover:text-pheromone-light"
                >
                  hello@tenbeltz.com
                </a>
              </li>
            </ul>
            <p class="mt-4 text-sm text-slate-300">{t('policies.legal.lssi')}</p>
          </section>

          <section class="rounded-2xl border border-pheromone-purple/20 bg-[#0B0122CC]/80 px-6 py-6">
            <h2 class="text-xl font-semibold">{t('policies.responsible.title')}</h2>
            <p class="mt-2 text-sm text-slate-300">
              {t('policies.responsible.text')}
              <a
                href="mailto:hello@tenbeltz.com"
                class="ml-1 text-pheromone-purple underline underline-offset-2 hover:text-pheromone-light"
              >
                hello@tenbeltz.com
              </a>
              .
            </p>
            <p class="mt-3 text-sm text-slate-300">{t('policies.responsible.dpo')}</p>
          </section>

          <section class="rounded-2xl border border-pheromone-purple/20 bg-[#0B0122CC]/80 px-6 py-6">
            <h2 class="text-xl font-semibold">{t('policies.data.title')}</h2>
            <p class="mt-2 text-sm text-slate-300">{t('policies.data.intro')}</p>
            <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-slate-300">
              <li>{t('policies.data.list.1')}</li>
              <li>{t('policies.data.list.2')}</li>
              <li>{t('policies.data.list.3')}</li>
              <li>{t('policies.data.list.4')}</li>
              <li>{t('policies.data.list.5')}</li>
            </ul>
            <p class="mt-4 text-sm text-slate-300">{t('policies.data.note')}</p>
          </section>

          <section class="rounded-2xl border border-pheromone-purple/20 bg-[#0B0122CC]/80 px-6 py-6">
            <h2 class="text-xl font-semibold">{t('policies.purpose.title')}</h2>
            <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-slate-300">
              <li>{t('policies.purpose.list.1')}</li>
              <li>{t('policies.purpose.list.2')}</li>
              <li>{t('policies.purpose.list.3')}</li>
              <li>{t('policies.purpose.list.4')}</li>
              <li>{t('policies.purpose.list.5')}</li>
              <li>{t('policies.purpose.list.6')}</li>
            </ul>
          </section>

          <section class="rounded-2xl border border-pheromone-purple/20 bg-[#0B0122CC]/80 px-6 py-6">
            <h2 class="text-xl font-semibold">{t('policies.legalbasis.title')}</h2>
            <p class="mt-2 text-sm text-slate-300">{t('policies.legalbasis.intro')}</p>
            <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-slate-300">
              <li>{t('policies.legalbasis.list.1')}</li>
              <li>{t('policies.legalbasis.list.2')}</li>
              <li>{t('policies.legalbasis.list.3')}</li>
              <li>{t('policies.legalbasis.list.4')}</li>
            </ul>
          </section>

          <section class="rounded-2xl border border-pheromone-purple/20 bg-[#0B0122CC]/80 px-6 py-6">
            <h2 class="text-xl font-semibold">{t('policies.retention.title')}</h2>
            <p class="mt-2 text-sm text-slate-300">
              {t('policies.retention.text')}
            </p>
            <p class="mt-3 rounded-lg border border-amber-400/40 bg-amber-400/10 px-4 py-3 text-sm text-amber-200">
              {t('policies.retention.pending')}
            </p>
          </section>

          <section class="rounded-2xl border border-pheromone-purple/20 bg-[#0B0122CC]/80 px-6 py-6">
            <h2 class="text-xl font-semibold">{t('policies.recipients.title')}</h2>
            <p class="mt-2 text-sm text-slate-300">
              {t('policies.recipients.text')}
            </p>
            <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-slate-300">
              <li>{t('policies.recipients.list.1')}</li>
              <li>{t('policies.recipients.list.2')}</li>
            </ul>
            <p class="mt-3 rounded-lg border border-amber-400/40 bg-amber-400/10 px-4 py-3 text-sm text-amber-200">
              {t('policies.recipients.list.3')}
            </p>
            <p class="mt-3 text-sm text-slate-300">{t('policies.recipients.outro')}</p>
          </section>

          <section class="rounded-2xl border border-pheromone-purple/20 bg-[#0B0122CC]/80 px-6 py-6">
            <h2 class="text-xl font-semibold">{t('policies.transfers.title')}</h2>
            <p class="mt-2 text-sm text-slate-300">{t('policies.transfers.text')}</p>
            <p class="mt-3 rounded-lg border border-amber-400/40 bg-amber-400/10 px-4 py-3 text-sm text-amber-200">
              {t('policies.transfers.pending')}
            </p>
          </section>

          <section class="rounded-2xl border border-pheromone-purple/20 bg-[#0B0122CC]/80 px-6 py-6">
            <h2 class="text-xl font-semibold">{t('policies.security.title')}</h2>
            <p class="mt-2 text-sm text-slate-300">{t('policies.security.intro')}</p>
            <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-slate-300">
              <li>{t('policies.security.list.1')}</li>
              <li>{t('policies.security.list.2')}</li>
              <li>{t('policies.security.list.3')}</li>
              <li>{t('policies.security.list.4')}</li>
            </ul>
            <p class="mt-3 rounded-lg border border-amber-400/40 bg-amber-400/10 px-4 py-3 text-sm text-amber-200">
              {t('policies.security.pending')}
            </p>
            <p class="mt-3 text-sm text-slate-300">{t('policies.security.scope')}</p>
          </section>

          <section class="rounded-2xl border border-pheromone-purple/20 bg-[#0B0122CC]/80 px-6 py-6">
            <h2 class="text-xl font-semibold">{t('policies.rights.title')}</h2>
            <p class="mt-2 text-sm text-slate-300">{t('policies.rights.intro')}</p>
            <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-slate-300">
              <li>{t('policies.rights.list.1')}</li>
              <li>{t('policies.rights.list.2')}</li>
              <li>{t('policies.rights.list.3')}</li>
              <li>{t('policies.rights.list.4')}</li>
              <li>{t('policies.rights.list.5')}</li>
              <li>{t('policies.rights.list.6')}</li>
              <li>{t('policies.rights.list.7')}</li>
            </ul>
            <p class="mt-4 text-sm text-slate-300">{t('policies.rights.howto')}</p>
            <p class="mt-3 text-sm text-slate-300">{t('policies.rights.aepd')}</p>
          </section>

          <section
            id="cookies"
            class="rounded-2xl border border-pheromone-purple/20 bg-[#0B0122CC]/80 px-6 py-6"
          >
            <h2 class="text-xl font-semibold">{t('policies.cookies.title')}</h2>
            <p class="mt-2 text-sm text-slate-300">
              {t('policies.cookies.intro')}
            </p>
            <ul class="mt-3 list-disc space-y-2 pl-5 text-sm text-slate-300">
              <li>
                <span class="font-semibold text-white">{t('policies.cookies.list.1.name')}</span>{t('policies.cookies.list.1.desc')}
              </li>
              <li>
                <span class="font-semibold text-white">{t('policies.cookies.list.2.name')}</span>{t('policies.cookies.list.2.desc')}
              </li>
            </ul>
            <p class="mt-4 text-sm text-slate-300">{t('policies.cookies.outro')}</p>
          </section>

          <section class="rounded-2xl border border-pheromone-purple/20 bg-[#0B0122CC]/80 px-6 py-6">
            <h2 class="text-xl font-semibold">{t('policies.usage.title')}</h2>
            <p class="mt-2 text-sm text-slate-300">{t('policies.usage.text')}</p>
            <p class="mt-3 text-sm text-slate-300">{t('policies.usage.links')}</p>
            <p class="mt-3 text-sm text-slate-300">{t('policies.usage.liability')}</p>
          </section>

          <section class="rounded-2xl border border-pheromone-purple/20 bg-[#0B0122CC]/80 px-6 py-6">
            <h2 class="text-xl font-semibold">{t('policies.law.title')}</h2>
            <p class="mt-2 text-sm text-slate-300">{t('policies.law.text')}</p>
          </section>

          <section class="rounded-2xl border border-pheromone-purple/20 bg-[#0B0122CC]/80 px-6 py-6">
            <h2 class="text-xl font-semibold">{t('policies.changes.title')}</h2>
            <p class="mt-2 text-sm text-slate-300">{t('policies.changes.text')}</p>
            <p class="mt-3 text-sm text-slate-400">
              <span class="font-semibold text-white">{t('policies.updated.label')}</span>
              {' '}{t('policies.updated.date')}
            </p>
          </section>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
