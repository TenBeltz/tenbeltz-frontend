            </g>
            <g>
              <rect x="20" y="35" width="60" height="40" rx="6" fill="#0B0122" stroke="#C45BFF" stroke-opacity="0.45" />
              <text x="50" y="59" text-anchor="middle" font-family="'IBM Plex Mono', monospace" font-size="9" fill="#E5C6F3" letter-spacing="1.2">data</text>
            </g>
            <g>
              <rect x="135" y="25" width="80" height="60" rx="8" fill="#120330" stroke="#C45BFF" stroke-opacity="0.85" />
              <text x="175" y="52" text-anchor="middle" font-family="'IBM Plex Mono', monospace" font-size="9" fill="#FFFFFF" letter-spacing="1.2">model</text>
              <text x="175" y="65" text-anchor="middle" font-family="'IBM Plex Mono', monospace" font-size="7" fill="#E5C6F3" opacity="0.7">+ guardrails</text>
            </g>
            <g>
              <rect x="270" y="35" width="80" height="40" rx="6" fill="#0B0122" stroke="#79CAFF" stroke-opacity="0.75" />
