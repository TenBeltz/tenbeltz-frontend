---
import Banner from '@/components/Banner.astro';
import Header from '@/components/Header.astro';
import HomeHero from '@/components/HomeHero.astro';
import Footer from '@/components/Footer.astro';
import Layout from '@/layouts/Layout.astro';
import Contact from '@/components/Contact.astro';
import { LandingPageMotion } from '@/components/LandingPageMotion';
import { ScrollReveal } from '@/components/ScrollReveal';
import { ReactComponent as AiIntegrationsIcon } from '@/assets/icons/ai-integrations-outline.svg';
import { ReactComponent as DocumentsIcon } from '@/assets/icons/documents-outline.svg';
import { ReactComponent as PackageSearchIcon } from '@/assets/icons/package-search-outline.svg';
import { ReactComponent as SecureIcon } from '@/assets/icons/secure-outline.svg';
import { ReactComponent as PeopleIcon } from '@/assets/icons/people-outline.svg';
import { getLangFromUrl } from '@/i18n/utils';
import { getServicesCopy } from '@/i18n/services';
import { getRelativeLocaleUrl } from 'astro:i18n';

const lang = getLangFromUrl(Astro.url);
const whoBehindSlug = lang === 'en' ? '/who-is-behind' : '/quien-esta-detras';
const servicesHref = getRelativeLocaleUrl(lang, '/services');
const whoBehindHref = getRelativeLocaleUrl(lang, whoBehindSlug);
const servicesCopy = getServicesCopy(lang);

const fillIconProps = { width: 22, height: 22, fill: '#E5C6F3' };
const strokeIconProps = { width: 22, height: 22, fill: 'none', stroke: '#E5C6F3', strokeWidth: 1.5 };

const content = lang === 'en'
  ? {
      seo: {
        title: 'TenBeltz | External AI engineering team for software companies',
        description: 'We help SaaS teams and software consultancies define, validate, and ship reliable AI systems with clear delivery criteria.',
      },
      hero: {
        title: 'Your external team',
        highlight: 'for AI engineering',
        subtitle: 'We help SaaS teams and software consultancies define, validate, and ship reliable, measurable, and profitable AI projects.',
        primaryText: 'Request proposal',
        secondaryText: 'How we work',
        microcopy: 'We reply in less than 48h',
        proofPoints: ['Clear viability', 'Evals and observability', 'Real integration', 'Cost control'],
      },
      segments: {
        title: 'We work with two kinds of software teams',
        items: [
          {
            title: 'SaaS companies',
            description: 'Teams that want to introduce AI or fix a feature that already reached production with poor reliability, high cost, or weak operating criteria.',
            bullets: ['New AI roadmap', 'Broken AI feature', 'Need for evals and observability'],
          },
          {
            title: 'Software consultancies',
            description: 'Teams that need sharper technical criteria to scope, sell, and deliver AI projects for their own clients without improvising architecture or requirements.',
            bullets: ['Pre-sales support', 'Project planning', 'Delivery foundation'],
          },
        ],
      },
      problem: {
        title: 'Most AI projects fail before production or when they finally get there',
        intro: 'The issue is rarely adding a model. The issue is knowing what to build, what data is needed, and how to operate it without hurting product, margin, or trust.',
        points: [
          'No clear viability criteria for the use case',
          'Built without enough data or evaluation coverage',
          'Costs explode when traffic grows',
          'Reliability breaks under real usage',
          'No observability, guardrails, or failure signals',
          'Projects sold without asking clients for what is needed',
        ],
      },
      value: {
        title: 'We step in where engineering judgment is actually needed',
        intro: 'TenBeltz is not an AI agency and not a generic consultancy. We define the case, structure the system, and help the team carry it into production with explicit delivery criteria.',
        promises: ['We do not sell demos', 'We do not sell hours without context'],
        capabilitiesTitle: 'We design AI systems that are:',
        capabilities: ['Decidable', 'Measurable', 'Observable', 'Maintainable'],
      },
      deliverables: {
        title: 'What clients actually walk away with',
        items: [
          {
            title: 'Clear viability decision',
            description: 'A go / no-go answer grounded in engineering, not intuition.',
          },
          {
            title: 'Recommended architecture',
            description: 'A system shape aligned with constraints, reliability, and margin.',
          },
          {
            title: 'Tooling and stack guidance',
            description: 'Practical choices for providers, frameworks, and orchestration.',
          },
          {
            title: 'Data and dataset requirements',
            description: 'What is missing, what quality is needed, and how to structure it.',
          },
          {
            title: 'Golden set and eval approach',
            description: 'A usable way to measure success before and after launch.',
          },
          {
            title: 'Observability plan',
            description: 'Signals, metrics, and alerts to monitor the system in production.',
          },
          {
            title: 'Risk map and guardrails',
            description: 'Failure modes, safeguards, and operating limits identified upfront.',
          },
          {
            title: 'Technical roadmap',
            description: 'Sequenced priorities so delivery stays clear and implementation does not drift.',
          },
        ],
      },
      process: {
        title: 'From fuzzy idea to operable system',
        subtitle: 'We keep the process simple: understand the context, design the system, validate with real criteria, and either ship it or support the internal team.',
        steps: [
          { title: 'Context', detail: 'We understand business constraints, product reality, and the specific use case.' },
          { title: 'System design', detail: 'We define architecture, data needs, evals, guardrails, and delivery path.' },
          { title: 'Validation', detail: 'We ground decisions in measurable criteria instead of intuition or demo theater.' },
          { title: 'Production or partner', detail: 'We either take it through delivery or stay close as an external AI engineering partner.' },
        ],
      },
      fit: {
        title: 'Who this is for',
        yesTitle: 'Good fit',
        yes: [
          'You are a SaaS or consultancy with real software delivery behind the AI ambition.',
          'You need technical judgment, not a flashy prototype.',
          'You care about reliability, observability, integration, and cost.',
          'You want a partner that can challenge scope before implementation starts.',
        ],
        noTitle: 'Not a fit',
        no: [
          'You want a cheap prototype as fast as possible.',
          'You want to add AI without a clear use case or owner.',
          'You want to start building without defining success criteria first.',
        ],
      },
      founder: {
        eyebrow: 'Before you write',
        title: 'You work directly with Aritz',
        description: 'TenBeltz is founder-led. If you fill in the form, the reply comes from the person who will actually think through the project with you.',
        cta: 'Meet who is behind',
      },
      banner: {
        title: 'If the project matters, it is worth defining it properly from the start',
        paragraph: 'Share the context and we will tell you whether there is a strong fit and which way of working makes sense.',
        button: 'Request proposal',
      },
    }
  : {
      seo: {
        title: 'TenBeltz | Equipo externo de ingeniería IA para empresas de software',
        description: 'Ayudamos a empresas SaaS y consultoras de software a definir, validar y llevar a producción sistemas de IA con criterio técnico claro.',
      },
      hero: {
        title: 'Tu equipo externo',
        highlight: 'de ingeniería IA',
        subtitle: 'Ayudamos a empresas SaaS y consultoras de software a definir, validar y llevar a producción proyectos de IA fiables, medibles y rentables.',
        primaryText: 'Solicitar propuesta',
        secondaryText: 'Cómo trabajamos',
        microcopy: 'Respondemos en menos de 48h',
        proofPoints: ['Viabilidad clara', 'Evals y observabilidad', 'Integración real', 'Control de costes'],
      },
      segments: {
        title: 'Trabajamos con dos tipos de equipos de software',
        items: [
          {
            title: 'Empresas SaaS',
            description: 'Equipos que quieren introducir IA o corregir una feature que ya llegó a producción con poca fiabilidad, mucho coste o criterios operativos débiles.',
            bullets: ['Nueva iniciativa de IA', 'Feature de IA con problemas', 'Necesidad de evals y observabilidad'],
          },
          {
            title: 'Consultoras de software',
            description: 'Equipos que necesitan mejor criterio técnico para definir, vender y ejecutar proyectos de IA para sus propios clientes sin improvisar arquitectura ni requisitos.',
            bullets: ['Soporte en preventa', 'Planificación del proyecto', 'Base para delivery'],
          },
        ],
      },
      problem: {
        title: 'La mayoría de proyectos de IA fallan antes de producción o cuando por fin llegan a ella',
        intro: 'El problema rara vez es enchufar un modelo. El problema es saber qué construir, qué datos hacen falta y cómo operarlo sin dañar producto, margen ni confianza.',
        points: [
          'No hay criterio claro para decidir si el caso de uso merece la pena',
          'Se construye sin suficientes datos ni evaluación',
          'Los costes se disparan al crecer el tráfico',
          'La fiabilidad se rompe con uso real',
          'No hay observabilidad, guardrails ni señales de fallo',
          'Se vende el proyecto sin pedir al cliente lo necesario',
        ],
      },
      value: {
        title: 'Entramos donde de verdad hace falta criterio de ingeniería',
        intro: 'TenBeltz no es una agencia de IA ni una consultora genérica. Definimos el caso, estructuramos el sistema y ayudamos al equipo a llevarlo a producción con criterios de entrega explícitos.',
        promises: ['No vendemos demos', 'No vendemos horas sin contexto'],
        capabilitiesTitle: 'Diseñamos sistemas de IA que son:',
        capabilities: ['Decidibles', 'Medibles', 'Observables', 'Mantenibles'],
      },
      deliverables: {
        title: 'Qué se lleva realmente el cliente',
        items: [
          {
            title: 'Decisión clara de viabilidad',
            description: 'Un sí / no basado en ingeniería, no en intuición.',
          },
          {
            title: 'Arquitectura recomendada',
            description: 'Una estructura de sistema alineada con restricciones, fiabilidad y margen.',
          },
          {
            title: 'Guía de stack y tooling',
            description: 'Decisiones prácticas sobre proveedores, frameworks y orquestación.',
          },
          {
            title: 'Requisitos de datos y datasets',
            description: 'Qué falta, qué calidad se necesita y cómo conviene estructurarlo.',
          },
          {
            title: 'Golden set y enfoque de evals',
            description: 'Una forma usable de medir éxito antes y después del lanzamiento.',
          },
          {
            title: 'Plan de observabilidad',
            description: 'Señales, métricas y alertas para seguir el sistema en producción.',
          },
          {
            title: 'Mapa de riesgos y guardrails',
            description: 'Modos de fallo, salvaguardas y límites operativos definidos desde el inicio.',
          },
          {
            title: 'Roadmap técnico',
            description: 'Prioridades secuenciadas para que el delivery no se desordene.',
          },
        ],
      },
      process: {
        title: 'De idea difusa a sistema operable',
        subtitle: 'Mantenemos el proceso simple: entender el contexto, diseñar el sistema, validar con criterios reales y llevarlo a producción o acompañar al equipo.',
        steps: [
          { title: 'Contexto', detail: 'Entendemos restricciones de negocio, realidad de producto y caso de uso concreto.' },
          { title: 'Diseño de sistema', detail: 'Definimos arquitectura, necesidades de datos, evals, guardrails y camino de entrega.' },
          { title: 'Validación', detail: 'Aterrizamos decisiones con criterios medibles en lugar de intuición o teatro de demo.' },
          { title: 'Producción o partner', detail: 'O lo llevamos hasta delivery o nos quedamos cerca como equipo externo de ingeniería IA.' },
        ],
      },
      fit: {
        title: 'Para quién encaja',
        yesTitle: 'Encaja bien',
        yes: [
          'Eres un SaaS o una consultora con capacidad real de delivery de software.',
          'Necesitas criterio técnico, no un prototipo vistoso.',
          'Te importan fiabilidad, observabilidad, integración y costes.',
          'Quieres un partner que cuestione el alcance antes de empezar a construir.',
        ],
        noTitle: 'No encaja',
        no: [
          'Buscas un prototipo barato lo antes posible.',
          'Quieres meter IA sin un caso de uso ni un owner claros.',
          'Esperas empezar a construir sin definir criterios de éxito.',
        ],
      },
      founder: {
        eyebrow: 'Antes de escribir',
        title: 'Trabajas directamente con Aritz',
        description: 'TenBeltz es founder-led. Si rellenas el formulario, responde la persona que realmente va a pensar el proyecto contigo.',
        cta: 'Conoce quién está detrás',
      },
      banner: {
        title: 'Si el proyecto importa, conviene definirlo bien desde el principio',
        paragraph: 'Comparte el contexto y te diremos si hay encaje claro y qué forma de trabajo tiene sentido.',
        button: 'Solicitar propuesta',
      },
    };

const segmentCards = [
  { icon: AiIntegrationsIcon, iconProps: fillIconProps, ...content.segments.items[0] },
  { icon: PeopleIcon, iconProps: strokeIconProps, ...content.segments.items[1] },
];

const homeModalityIcons = [DocumentsIcon, PackageSearchIcon, SecureIcon, PeopleIcon];
const modalityCards = servicesCopy.home.cards.map((card, index) => ({
  ...card,
  icon: homeModalityIcons[index],
  iconProps: strokeIconProps,
}));
---

<Layout
  title={content.seo.title}
  description={content.seo.description}
  canonical="https://tenbeltz.com"
>
  <Header />
  <main class="relative z-10 flex flex-col flex-1 overflow-x-hidden">
    <HomeHero
      title={content.hero.title}
      highlight={content.hero.highlight}
      subtitle={content.hero.subtitle}
      primaryHref="#contact-section"
      primaryText={content.hero.primaryText}
      secondaryHref="#como-trabajamos"
      secondaryText={content.hero.secondaryText}
      microcopy={content.hero.microcopy}
      proofPoints={content.hero.proofPoints}
    />

    <section class="relative text-white section-shell">
      <div class="max-w-screen-xl px-4 py-20 mx-auto lg:px-16 lg:py-24">
        <ScrollReveal client:visible>
          <div class="max-w-3xl">
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-pheromone-light/80">TenBeltz</p>
            <h2 class="mt-3 text-4xl font-bold lg:text-5xl">{content.segments.title}</h2>
          </div>
        </ScrollReveal>
        <div class="grid grid-cols-1 gap-6 mt-10 lg:grid-cols-2">
          {segmentCards.map((item, index) => (
            <ScrollReveal client:visible delay={index * 120}>
              <div class="flex flex-col h-full gap-5 rounded-2xl border border-pheromone-purple/25 bg-[#0B0122CC]/80 px-6 py-7 shadow-[0_0_25px_rgba(3,7,18,0.35)] backdrop-blur-sm">
                <span class="flex h-11 w-11 items-center justify-center rounded-full bg-pheromone-purple/20">
                  <item.icon {...item.iconProps} />
                </span>
                <div class="flex flex-col gap-3">
                  <h3 class="text-2xl font-semibold">{item.title}</h3>
                  <p class="text-slate-300">{item.description}</p>
                </div>
                <ul class="flex flex-col gap-2 text-sm text-slate-300">
                  {item.bullets.map((bullet) => <li>• {bullet}</li>)}
                </ul>
              </div>
            </ScrollReveal>
          ))}
        </div>
      </div>
    </section>

    <section id="problemas" class="relative text-white overflow-hidden">
      <div class="absolute inset-0 opacity-40 bg-grid pointer-events-none [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_75%)]"></div>
      <div class="pointer-events-none absolute top-10 -right-32 h-[28rem] w-[28rem] rounded-full bg-pheromone-purple/15 blur-3xl"></div>
      <div class="pointer-events-none absolute bottom-20 -left-24 h-80 w-80 rounded-full bg-sapphire-siren/10 blur-3xl"></div>
      <div class="relative max-w-screen-xl px-4 py-24 mx-auto lg:px-16 lg:py-32">
        <ScrollReveal client:visible>
          <div class="mx-auto max-w-4xl text-center">
            <p class="text-sm font-semibold uppercase tracking-[0.32em] text-pheromone-light/80">Problem</p>
            <h2 class="mt-5 text-4xl font-bold leading-[1.05] tracking-tight lg:text-6xl">
              {content.problem.title}
            </h2>
            <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-300">{content.problem.intro}</p>
          </div>
        </ScrollReveal>
        <ScrollReveal client:visible>
          <div class="mx-auto mt-16 grid max-w-5xl grid-cols-1 gap-x-16 gap-y-10 md:grid-cols-2">
            {content.problem.points.map((point, index) => (
              <div class="flex items-start gap-5" style={`animation-delay: ${index * 60}ms`}>
                <span class="shrink-0 pt-1 font-mono text-sm font-semibold tracking-widest text-pheromone-light tabular-nums">
                  0{index + 1}
                </span>
                <p class="border-l border-pheromone-purple/25 pl-5 text-base leading-relaxed text-slate-200 lg:text-lg">
                  {point}
                </p>
              </div>
            ))}
          </div>
        </ScrollReveal>
      </div>
    </section>

    <section class="relative text-white">
      <div class="pointer-events-none absolute -bottom-10 left-0 h-64 w-64 rounded-full bg-pheromone-purple/20 blur-3xl"></div>
      <div class="max-w-screen-xl px-4 py-20 mx-auto lg:px-16 lg:py-24">
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-[1fr_1.1fr] lg:gap-20">
          <ScrollReveal client:visible>
            <div class="max-w-xl">
              <p class="text-sm font-semibold uppercase tracking-[0.28em] text-pheromone-light/80">Value</p>
              <h2 class="mt-3 text-4xl font-bold leading-tight lg:text-5xl">{content.value.title}</h2>
              <p class="mt-5 text-lg text-slate-300">{content.value.intro}</p>
            </div>
          </ScrollReveal>
          <ScrollReveal client:visible>
            <div class="flex flex-col gap-10">
              <div class="flex flex-col gap-0">
                {content.value.promises.map((promise, index) => (
                  <div class={`flex items-baseline gap-5 py-5 ${index < content.value.promises.length - 1 ? 'border-b border-pheromone-purple/20' : ''}`}>
                    <span aria-hidden="true" class="font-mono text-2xl font-light text-sapphire-siren/80">×</span>
                    <p class="text-xl font-semibold leading-snug text-white lg:text-2xl">{promise}</p>
                  </div>
                ))}
              </div>
              <div>
                <p class="font-mono text-xs font-semibold uppercase tracking-[0.32em] text-pheromone-light/80">
                  {content.value.capabilitiesTitle}
                </p>
                <div class="mt-5 flex flex-wrap gap-2.5">
                  {content.value.capabilities.map((capability, index) => (
                    <span class="inline-flex items-center gap-2.5 rounded-full border border-pheromone-purple/30 bg-pheromone-purple/[0.08] px-4 py-2 text-sm font-semibold text-white backdrop-blur-sm transition-colors duration-300 hover:border-pheromone-purple/60 hover:bg-pheromone-purple/15">
                      <span class="font-mono text-[10px] text-pheromone-light/70">0{index + 1}</span>
                      {capability}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </ScrollReveal>
        </div>
      </div>
    </section>

    <section id="que-hacemos" class="relative text-white bg-grid">
      <div class="max-w-screen-xl px-4 py-20 mx-auto lg:px-16 lg:py-24">
        <ScrollReveal client:visible>
          <div class="max-w-3xl">
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-pheromone-light/80">Ways of working</p>
            <h2 class="mt-3 text-4xl font-bold lg:text-5xl">{servicesCopy.home.title}</h2>
            <p class="mt-5 text-lg text-slate-300">{servicesCopy.home.intro}</p>
          </div>
        </ScrollReveal>
        <div class="grid grid-cols-1 gap-5 mt-10 md:grid-cols-2">
          {modalityCards.map((item, index) => (
            <ScrollReveal client:visible delay={index * 90}>
              <div data-tilt-card class="tilt-card rounded-2xl h-full">
                <div data-tilt-inner class="tilt-card__inner flex h-full flex-col gap-5 rounded-2xl border border-pheromone-purple/25 bg-[#0B0122CC]/80 px-6 py-7 shadow-[0_0_25px_rgba(3,7,18,0.35)] backdrop-blur-sm">
                  <div class="flex items-center justify-between gap-4">
                    <span class="inline-flex rounded-full border border-pheromone-purple/40 bg-pheromone-purple/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-pheromone-light">
                      {item.tag}
                    </span>
                    <span class="flex h-11 w-11 items-center justify-center rounded-full bg-pheromone-purple/20">
                      <item.icon {...item.iconProps} />
                    </span>
                  </div>
                  <div class="flex flex-col gap-3">
                    <h3 class="text-2xl font-semibold">{item.title}</h3>
                    <p class="text-slate-300">{item.description}</p>
                  </div>
                  {item.variants ? (
                    <div class="mt-auto flex flex-col gap-3">
                      <p class="font-mono text-[11px] font-semibold uppercase tracking-[0.3em] text-pheromone-light/70">
                        {servicesCopy.home.variantsLabel}
                      </p>
                      {item.variants.map((variant) => (
                        <a
                          href={`${servicesHref}#service-${variant.serviceId}`}
                          class="group flex flex-col gap-2 rounded-xl border border-pheromone-purple/20 bg-white/[0.02] px-4 py-3 transition-colors hover:border-pheromone-purple/45 hover:bg-white/[0.05]"
                        >
                          <div class="flex items-center gap-2">
                            <span class="inline-flex rounded-full border border-pheromone-purple/40 bg-pheromone-purple/10 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-[0.22em] text-pheromone-light">
                              {variant.tag}
                            </span>
                            <span class="text-sm font-semibold text-white">{variant.title}</span>
                            <span aria-hidden="true" class="ml-auto text-pheromone-light/70 transition-transform group-hover:translate-x-0.5">&rarr;</span>
                          </div>
                          <p class="text-xs leading-relaxed text-slate-300">{variant.description}</p>
                        </a>
                      ))}
                    </div>
                  ) : (
                    <ul class="mt-auto flex flex-col gap-2 text-sm text-slate-300">
                      {item.bullets?.map((bullet) => <li>• {bullet}</li>)}
                    </ul>
                  )}
                </div>
              </div>
            </ScrollReveal>
          ))}
        </div>
        <ScrollReveal client:visible>
          <div class="mt-10">
            <a href={servicesHref} class="inline-flex items-center justify-center rounded-xl border border-white/12 bg-white/[0.04] px-6 py-3 text-base font-semibold text-white/90 backdrop-blur-md transition-colors duration-300 hover:border-white/25 hover:bg-white/[0.08]">
              {lang === 'en' ? 'See the service structure' : 'Ver la estructura de servicios'}
            </a>
          </div>
        </ScrollReveal>
      </div>
    </section>

    <section class="relative text-white">
      <div class="max-w-screen-xl px-4 py-20 mx-auto lg:px-16 lg:py-24">
        <ScrollReveal client:visible>
          <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div class="max-w-2xl">
              <p class="text-sm font-semibold uppercase tracking-[0.28em] text-pheromone-light/80">Deliverables</p>
              <h2 class="mt-3 text-4xl font-bold lg:text-5xl">{content.deliverables.title}</h2>
            </div>
            <p class="font-mono text-xs uppercase tracking-[0.3em] text-slate-500">
              08 / {lang === 'en' ? 'artifacts' : 'entregables'}
            </p>
          </div>
        </ScrollReveal>

        <div class="mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-4 md:auto-rows-[11rem]">
          <ScrollReveal client:visible className="sm:col-span-2 md:row-span-2">
            <div class="group relative flex h-full flex-col justify-between overflow-hidden rounded-2xl border border-pheromone-purple/40 bg-gradient-to-br from-[#16002E] via-[#0D0124] to-[#240044] p-7 shadow-[0_0_40px_rgba(96,43,182,0.2)]">
              <div class="pointer-events-none absolute -top-16 -right-16 h-60 w-60 rounded-full bg-pheromone-purple/25 blur-3xl"></div>
              <div class="relative flex items-center justify-between">
                <span class="font-mono text-xs font-semibold uppercase tracking-[0.32em] text-pheromone-light">01 · Core</span>
                <span aria-hidden="true" class="font-mono text-[clamp(3rem,6vw,4.5rem)] font-bold leading-none text-pheromone-purple/20">01</span>
              </div>
