---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Banner from '@/components/Banner.astro';
import Contact from '@/components/Contact.astro';
import { ScrollReveal } from '@/components/ScrollReveal';
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

import { ReactComponent as ProcessIcon } from '@/assets/icons/process-outline.svg';
import { ReactComponent as ChartOutlineIcon } from '@/assets/icons/chart-outline.svg';
import { ReactComponent as GlassesIcon } from '@/assets/icons/glasses-outline.svg';
import { ReactComponent as ChartLineIcon } from '@/assets/icons/chart-line-outline.svg';
import { ReactComponent as SecureIcon } from '@/assets/icons/secure-outline.svg';
import { ReactComponent as AiIntegrationsIcon } from '@/assets/icons/ai-integrations-outline.svg';
import { ReactComponent as TaskDoneIcon } from '@/assets/icons/task-done-outline.svg';
import { ReactComponent as PeopleIcon } from '@/assets/icons/people-outline.svg';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const whoBehindSlug = lang === 'en' ? '/who-is-behind' : '/quien-esta-detras';
const canonical = `https://tenbeltz.com${lang === 'en' ? '/en' : ''}${whoBehindSlug}`;

const strokeIconProps = { width: 22, height: 22, fill: 'none', stroke: '#E5C6F3', strokeWidth: 1.5 };

const principles = [
  { icon: ProcessIcon, title: t('whobehind.principles.items.0.title'), desc: t('whobehind.principles.items.0.desc') },
  { icon: ChartOutlineIcon, title: t('whobehind.principles.items.1.title'), desc: t('whobehind.principles.items.1.desc') },
  { icon: GlassesIcon, title: t('whobehind.principles.items.2.title'), desc: t('whobehind.principles.items.2.desc') },
  { icon: ChartLineIcon, title: t('whobehind.principles.items.3.title'), desc: t('whobehind.principles.items.3.desc') },
];

const recognition = [
  { icon: TaskDoneIcon, label: t('whobehind.recognition.items.0.label'), text: t('whobehind.recognition.items.0.text') },
  { icon: PeopleIcon, label: t('whobehind.recognition.items.1.label'), text: t('whobehind.recognition.items.1.text') },
  { icon: AiIntegrationsIcon, label: t('whobehind.recognition.items.2.label'), text: t('whobehind.recognition.items.2.text') },
];

const biiakUrl = t('whobehind.elsewhere.biiak.url');
---

<Layout
  title={t('whobehind.seo.title')}
  description={t('whobehind.seo.description')}
  canonical={canonical}
>
  <Header />
  <main class="relative z-10 flex flex-col flex-1 overflow-x-hidden pt-24 lg:pt-28">
    <!-- 1. Hero -->
    <section class="relative overflow-hidden text-white section-shell">
      <div class="pointer-events-none absolute -top-24 right-[-6rem] h-[28rem] w-[28rem] rounded-full bg-pheromone-purple/20 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-20 left-[-6rem] h-[24rem] w-[24rem] rounded-full bg-sapphire-siren/30 blur-3xl"></div>
      <div class="relative grid max-w-screen-xl grid-cols-1 gap-12 px-4 py-16 mx-auto lg:grid-cols-[1.1fr_1fr] lg:px-16 lg:py-20 lg:gap-16 items-center">
        <ScrollReveal client:visible>
          <div class="flex flex-col gap-y-6">
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-pheromone-light/80">
              {t('whobehind.hero.eyebrow')}
            </p>
            <h1 class="text-4xl font-extrabold leading-tight lg:text-6xl">
              {t('whobehind.hero.title')}{' '}
              <span class="bg-gradient-to-r from-[#9238D6] to-[#C45BFF] bg-clip-text text-transparent">
                {t('whobehind.hero.highlight')}
              </span>
            </h1>
            <p class="max-w-xl text-lg text-slate-300">{t('whobehind.hero.subtitle')}</p>
          </div>
        </ScrollReveal>
        <ScrollReveal client:visible direction="right">
          <div class="flex flex-col items-center gap-y-5 lg:items-start">
            <div class="relative">
              <span aria-hidden="true" class="absolute inset-0 -m-3 rounded-full bg-gradient-to-br from-pheromone-purple/60 via-pheromone-light/30 to-transparent blur-xl"></span>
              <div class="relative rounded-full p-[3px] bg-gradient-to-br from-pheromone-light via-pheromone-purple to-sapphire-siren shadow-[0_0_40px_rgba(146,56,214,0.35)]">
                <img
                  src="/images/team/aritz.webp"
                  alt={t('whobehind.hero.photoAlt')}
                  width="200"
                  height="200"
                  loading="eager"
                  decoding="async"
                  class="block h-44 w-44 lg:h-52 lg:w-52 rounded-full object-cover bg-obsidian-shard"
                />
              </div>
            </div>
            <div class="flex flex-col items-center gap-y-1 text-center lg:items-start lg:text-left">
              <p class="text-2xl font-bold text-white">{t('whobehind.hero.name')}</p>
              <p class="text-base text-slate-300">{t('whobehind.hero.role')}</p>
              <p class="text-sm uppercase tracking-widest text-slate-400">{t('whobehind.hero.location')}</p>
            </div>
            <ul class="flex flex-wrap items-center justify-center gap-2 lg:justify-start">
              <li>
                <span class="inline-flex items-center rounded-full border border-pheromone-purple/60 bg-pheromone-purple/10 px-3 py-1.5 text-xs font-semibold text-pheromone-light">
                  {t('whobehind.hero.chip.0')}
                </span>
              </li>
              <li>
                <span class="inline-flex items-center rounded-full border border-pheromone-purple/60 bg-pheromone-purple/10 px-3 py-1.5 text-xs font-semibold text-pheromone-light">
                  {t('whobehind.hero.chip.1')}
                </span>
              </li>
              <li>
                <span class="inline-flex items-center rounded-full border border-pheromone-purple/60 bg-pheromone-purple/10 px-3 py-1.5 text-xs font-semibold text-pheromone-light">
                  {t('whobehind.hero.chip.2')}
                </span>
              </li>
            </ul>
          </div>
        </ScrollReveal>
      </div>
    </section>

    <!-- 2. Story -->
    <section class="relative text-white bg-grid">
      <div class="grid max-w-screen-xl grid-cols-1 gap-12 px-4 py-20 mx-auto lg:grid-cols-[1.1fr_1fr] lg:px-16 lg:py-24">
        <ScrollReveal client:visible>
          <div class="flex flex-col gap-y-5 max-w-xl">
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-pheromone-light/80">
              {t('whobehind.story.eyebrow')}
            </p>
            <h2 class="text-4xl font-bold">{t('whobehind.story.title')}</h2>
            <p class="text-lg text-slate-300">{t('whobehind.story.p1')}</p>
            <p class="text-lg text-slate-300">{t('whobehind.story.p2')}</p>
          </div>
        </ScrollReveal>
        <ScrollReveal client:visible direction="right">
          <figure class="relative h-full">
            <div class="relative flex h-full flex-col justify-center rounded-2xl border border-pheromone-purple/30 bg-gradient-to-br from-[#16002E] to-[#240044] px-6 py-8 shadow-[0_0_40px_rgba(3,7,18,0.45)] backdrop-blur-sm">
              <span aria-hidden="true" class="absolute -top-4 left-6 text-6xl font-serif leading-none text-pheromone-light/50">&ldquo;</span>
              <blockquote class="text-xl font-semibold leading-relaxed text-white lg:text-2xl">
                {t('whobehind.story.quote')}
              </blockquote>
              <figcaption class="mt-5 text-sm uppercase tracking-widest text-pheromone-light/80">
                {t('whobehind.story.quoteAuthor')}
              </figcaption>
            </div>
          </figure>
        </ScrollReveal>
      </div>
    </section>

    <!-- 3. Principles -->
    <section class="relative text-white">
      <div class="pointer-events-none absolute top-10 left-[-4rem] h-64 w-64 rounded-full bg-pheromone-purple/20 blur-3xl"></div>
      <div class="flex flex-col max-w-screen-xl px-4 py-20 mx-auto lg:px-16 lg:py-24 gap-y-10">
        <ScrollReveal client:visible>
          <div class="max-w-3xl flex flex-col gap-y-4">
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-pheromone-light/80">
              {t('whobehind.principles.eyebrow')}
            </p>
            <h2 class="text-4xl font-bold">{t('whobehind.principles.title')}</h2>
            <p class="text-lg text-slate-300">{t('whobehind.principles.subtitle')}</p>
          </div>
        </ScrollReveal>
        <ScrollReveal client:visible>
          <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
            {principles.map((item) => (
              <div class="flex flex-col gap-y-4 rounded-2xl border border-pheromone-purple/25 bg-[#0B0122CC]/80 px-5 py-6 shadow-[0_0_25px_rgba(3,7,18,0.35)] backdrop-blur-sm">
                <span class="flex h-11 w-11 items-center justify-center rounded-full bg-pheromone-purple/20">
                  <item.icon {...strokeIconProps} />
                </span>
                <h3 class="text-xl font-semibold text-white">{item.title}</h3>
                <p class="text-slate-300">{item.desc}</p>
              </div>
            ))}
          </div>
        </ScrollReveal>
      </div>
    </section>

    <!-- 4. Elsewhere -->
    <section class="relative text-white bg-grid">
      <div class="flex flex-col max-w-screen-xl px-4 py-20 mx-auto lg:px-16 lg:py-24 gap-y-10">
        <ScrollReveal client:visible>
          <div class="max-w-3xl flex flex-col gap-y-4">
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-pheromone-light/80">
              {t('whobehind.elsewhere.eyebrow')}
            </p>
            <h2 class="text-4xl font-bold">{t('whobehind.elsewhere.title')}</h2>
            <p class="text-lg text-slate-300">{t('whobehind.elsewhere.subtitle')}</p>
          </div>
        </ScrollReveal>
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
          <ScrollReveal client:visible>
            <div class="flex flex-col h-full gap-y-4 rounded-2xl border border-pheromone-purple/30 bg-gradient-to-br from-[#110126] to-[#1C0434] px-6 py-7">
              <span class="flex h-11 w-11 items-center justify-center rounded-full bg-pheromone-purple/20">
                <SecureIcon {...strokeIconProps} />
              </span>
              <h3 class="text-2xl font-semibold text-white">{t('whobehind.elsewhere.biiak.role')}</h3>
              <p class="text-slate-300">{t('whobehind.elsewhere.biiak.desc')}</p>
              <a
                href={biiakUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex w-fit items-center gap-x-2 text-sm font-semibold text-pheromone-light hover:text-white transition-colors"
              >
                {t('whobehind.elsewhere.biiak.cta')}
                <span aria-hidden="true">&rarr;</span>
              </a>
            </div>
          </ScrollReveal>
          <ScrollReveal client:visible direction="right">
            <div class="flex flex-col h-full gap-y-4 rounded-2xl border border-pheromone-purple/30 bg-gradient-to-br from-[#1A0032] to-[#2A0A44] px-6 py-7">
              <span class="flex h-11 w-11 items-center justify-center rounded-full bg-pheromone-purple/20">
                <AiIntegrationsIcon width="22" height="22" fill="#E5C6F3" />
              </span>
              <h3 class="text-2xl font-semibold text-white">{t('whobehind.elsewhere.irontec.role')}</h3>
              <p class="text-slate-300">{t('whobehind.elsewhere.irontec.desc')}</p>
            </div>
          </ScrollReveal>
        </div>
      </div>
    </section>

    <!-- 5. Recognition -->
    <section class="relative text-white">
      <div class="flex flex-col max-w-screen-xl px-4 py-20 mx-auto lg:px-16 lg:py-24 gap-y-10">
        <ScrollReveal client:visible>
          <div class="max-w-3xl flex flex-col gap-y-4">
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-pheromone-light/80">
              {t('whobehind.recognition.eyebrow')}
            </p>
            <h2 class="text-4xl font-bold">{t('whobehind.recognition.title')}</h2>
          </div>
        </ScrollReveal>
        <ScrollReveal client:visible>
          <ul class="grid grid-cols-1 gap-4 md:grid-cols-3">
            {recognition.map((item) => (
              <li class="flex items-start gap-4 rounded-xl border border-pheromone-purple/25 bg-[#0B0122CC]/80 px-5 py-5 backdrop-blur-sm">
                <span class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-pheromone-purple/20">
                  <item.icon {...strokeIconProps} width="20" height="20" />
                </span>
                <div class="flex flex-col gap-y-1">
                  <p class="text-xs font-semibold uppercase tracking-widest text-pheromone-light/80">{item.label}</p>
                  <p class="text-base font-medium text-white">{item.text}</p>
                </div>
              </li>
            ))}
          </ul>
        </ScrollReveal>
      </div>
    </section>

    <!-- 6. CTA -->
    <Banner
      title={t('whobehind.cta.title')}
      paragraph={t('whobehind.cta.paragraph')}
      buttonText={t('whobehind.cta.button')}
      buttonHref="#contact-section"
    />

    <!-- 7. Contact form -->
    <Contact />
  </main>
  <Footer />
</Layout>
