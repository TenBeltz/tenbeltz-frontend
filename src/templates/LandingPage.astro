                <span data-step-glow class="method-step-glow"></span>
                <div class="relative flex items-center justify-between">
                  <span class="font-mono text-[11px] font-semibold uppercase tracking-[0.32em] text-pheromone-light">
                    0{index + 1}
                  </span>
                  <span class="flex h-5 w-5 items-center justify-center rounded-full border border-pheromone-purple/40 bg-[#0B0122]">
                    <span class="h-1.5 w-1.5 rounded-full bg-pheromone-light"></span>
                  </span>
                </div>
                <p class="relative text-lg font-semibold text-white lg:text-xl">{step.title}</p>
                <p class="relative text-sm leading-relaxed text-slate-300">{step.detail}</p>
                <div class="relative mt-auto flex items-center gap-1 pt-2 font-mono text-[9px] uppercase tracking-[0.3em] text-pheromone-light/50">
                  <span class="inline-block h-px w-6 bg-pheromone-purple/50"></span>
                  <span>step</span>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div
