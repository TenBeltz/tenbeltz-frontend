      </div>
    </section>

    <section id="para-quien" class="relative text-white">
      <div class="max-w-screen-xl px-4 py-20 mx-auto lg:px-16 lg:py-24">
        <ScrollReveal client:visible>
          <div class="max-w-3xl">
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-pheromone-light/80">Fit</p>
            <h2 class="mt-3 text-4xl font-bold lg:text-5xl">{content.fit.title}</h2>
          </div>
        </ScrollReveal>
        <div class="mt-12 grid grid-cols-1 gap-6 lg:grid-cols-5">
          <ScrollReveal client:visible className="lg:col-span-3">
            <div class="relative h-full overflow-hidden rounded-3xl border border-cold-heights/25 bg-gradient-to-br from-[#0B2238] via-[#0B0122] to-[#120432] p-8 shadow-[0_0_40px_rgba(121,202,255,0.08)] lg:p-10">
              <div aria-hidden="true" class="pointer-events-none absolute -top-20 -right-20 h-72 w-72 rounded-full bg-cold-heights/15 blur-3xl"></div>
              <div class="relative flex items-center gap-3">
                <span class="inline-flex h-2 w-2 rounded-full bg-cold-heights shadow-[0_0_12px_rgba(121,202,255,0.8)]"></span>
