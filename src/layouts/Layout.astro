---
import "../styles/global.css";
import SEO from "@/components/SEO.astro"
import CookieConsent from "@/components/CookieConsent.astro";
import { getLangFromUrl } from "@/i18n/utils";

interface Props {
	title: string
	description: string
	canonical?: string
	noindex?: boolean
}

const { title, description, canonical, noindex } = Astro.props;
const lang = getLangFromUrl(Astro.url);
---

<!doctype html>
<html lang={lang}>
	<head>
		{/* IBM Plex Sans is self-hosted; @font-face lives in src/styles/global.css.
		    Only the latin subset at weight 400 is preloaded: it is the default body
		    weight and is needed on every page. The latin-ext file and the other
		    weights are left to normal discovery so they do not compete for
		    bandwidth with the critical render path. */}
		<link
			rel="preload"
			as="font"
			type="font/woff2"
			href="/fonts/ibm-plex-sans-latin.woff2"
			crossorigin
		/>
		<SEO
			title={title}
			canonical={canonical}
			description={description}
			lang={lang}
			noindex={noindex}
		/>
	</head>
	<body class="flex flex-col min-h-screen overflow-x-hidden bg-obsidian-shard">
		<slot />
		<CookieConsent />
	</body>
</html>
<style is:global>
	html {
		scroll-behavior: smooth;
	}
</style>
