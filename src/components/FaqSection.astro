---
import { ReactComponent as ChevronDown } from '@/assets/icons/chevron-down-outline.svg';
import { ScrollReveal } from '@/components/ScrollReveal';
import { getLangFromUrl } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);

interface FaqItem {
  question: string;
  answer: string;
}

const content = lang === 'en'
  ? {
      eyebrow: 'FAQ',
      title: 'Frequently asked questions',
      subtitlePre: 'Got another question and cannot find the answer? ',
      subtitleLink: 'Write to us',
      subtitlePost: ' and we will get back to you as soon as possible.',
      items: [
        {
          question: 'How do we know if an AI use case is viable in cost and scalability?',
          answer: 'We define the expected volume, the target cost per request, and the reliability metric before building anything.',
        },
        {
          question: 'How do you measure reliability in production?',
          answer: 'We combine automatic evals, a golden set, human review, and guardrails with fallback when the model fails.',
        },
        {
          question: 'How do you reduce costs without losing quality?',
          answer: 'We use cheap routes, caching, batching, mixed models, and per-feature limits.',
        },
        {
          question: 'What about sensitive data and privacy?',
          answer: 'We apply data classification, PII redaction, access policies, and full traceability.',
        },
        {
          question: 'What deliverables does a Gap Analysis or a sprint include?',
          answer: 'A phased roadmap, reliability metrics, a cost baseline, and a scaling plan.',
        },
        {
          question: 'Do you work with our current team and stack?',
          answer: 'Yes. We integrate with your product and engineering teams, leaving documentation and a handoff so everything stays operational.',
        },
      ] as FaqItem[],
    }
  : {
      eyebrow: 'FAQ',
      title: 'Preguntas frecuentes',
      subtitlePre: '¿Tienes otra pregunta y no encuentras la respuesta? ',
      subtitleLink: 'Escríbenos',
      subtitlePost: ' y te respondemos cuanto antes.',
      items: [
        {
          question: '¿Cómo saber si un caso de uso de IA es viable en costes y escalabilidad?',
          answer: 'Definimos el volumen esperado, el coste objetivo por petición y la métrica de fiabilidad antes de construir.',
        },
        {
          question: '¿Cómo medís la fiabilidad en producción?',
          answer: 'Combinamos evals automáticas, golden set, revisión humana y guardrails con fallback cuando el modelo falla.',
        },
        {
          question: '¿Cómo reducís costes sin perder calidad?',
          answer: 'Usamos rutas baratas, caching, batching, modelos mixtos y límites por feature.',
        },
        {
          question: '¿Qué pasa con datos sensibles y privacidad?',
          answer: 'Aplicamos clasificación de datos, redacción de PII, políticas de acceso y trazabilidad completa.',
        },
        {
          question: '¿Qué entregables incluye un Gap Analysis o un sprint?',
          answer: 'Hoja de ruta por fases, métricas de fiabilidad, baseline de costes y plan de escalado.',
        },
        {
          question: '¿Trabajáis con nuestro equipo y stack actual?',
          answer: 'Sí. Nos integramos con tu equipo de producto e ingeniería, dejando documentación y handoff para que todo quede operativo.',
        },
      ] as FaqItem[],
    };

const faqJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: content.items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
});
---

<section id="faq" class="relative text-white">
  <div class="pointer-events-none absolute top-16 right-[-5rem] h-64 w-64 rounded-full bg-pheromone-purple/15 blur-3xl"></div>
  <div class="max-w-screen-xl px-4 py-20 mx-auto lg:px-16 lg:py-24">
    <ScrollReveal client:visible>
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.28em] text-pheromone-light/80">{content.eyebrow}</p>
        <h2 class="mt-3 text-4xl font-bold lg:text-5xl">{content.title}</h2>
        <p class="mt-5 text-lg text-slate-300">
          {content.subtitlePre}<a href="#contact-section" class="font-semibold text-pheromone-light transition-colors hover:text-white">{content.subtitleLink}</a>{content.subtitlePost}
        </p>
      </div>
    </ScrollReveal>

    <div class="mt-10 grid grid-cols-1 gap-4 lg:grid-cols-2">
      {content.items.map((item, index) => (
        <ScrollReveal client:visible delay={index * 80}>
          <details class="group h-full rounded-2xl border border-pheromone-purple/25 bg-[#0B0122CC]/80 backdrop-blur-sm transition-colors open:border-pheromone-purple/50 hover:border-pheromone-purple/45">
            <summary class="flex cursor-pointer list-none items-start justify-between gap-4 px-6 py-5 [&::-webkit-details-marker]:hidden">
              <span class="text-lg font-semibold leading-snug text-white">{item.question}</span>
              <span class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-pheromone-purple/20">
                <ChevronDown
                  width="18"
                  height="18"
                  fill="none"
                  stroke="#E5C6F3"
                  strokeWidth="1.8"
                  aria-hidden="true"
                  className="transform transition-transform duration-200 group-open:rotate-180"
                />
              </span>
            </summary>
            <p class="px-6 pb-6 text-base leading-relaxed text-slate-300">{item.answer}</p>
          </details>
        </ScrollReveal>
      ))}
    </div>
  </div>
</section>

<script is:inline type="application/ld+json" set:html={faqJsonLd} />
