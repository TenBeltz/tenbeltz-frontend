            viewBox="0 0 100 10"
            preserveAspectRatio="none"
            fill="none"
            aria-hidden="true"
          >
            <defs>
              <linearGradient id="method-path-stroke" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#79CAFF" stop-opacity="0.4" />
                <stop offset="50%" stop-color="#C45BFF" stop-opacity="0.9" />
                <stop offset="100%" stop-color="#E5C6F3" stop-opacity="0.7" />
              </linearGradient>
            </defs>
            <path
              data-method-path
              d="M 0 5 Q 12.5 2, 25 5 T 50 5 T 75 5 T 100 5"
              stroke="url(#method-path-stroke)"
              stroke-width="0.35"
              vector-effect="non-scaling-stroke"
              fill="none"
              stroke-linecap="round"
            />
          </svg>

          <div class="method-stage__cards">
            {content.process.steps.map((step, index) => (
              <div
                data-method-step
                class="method-step-card relative flex flex-col gap-3 overflow-hidden rounded-2xl border border-pheromone-purple/25 bg-[#0B0122]/90 px-5 py-6 backdrop-blur-md"
