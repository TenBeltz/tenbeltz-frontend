---
import Banner from '@/components/Banner.astro';
import Header from '@/components/Header.astro';
import HomeHero from '@/components/HomeHero.astro';
import Footer from '@/components/Footer.astro';
import Layout from '@/layouts/Layout.astro';
import Contact from '@/components/Contact.astro';
import { LandingPageMotion } from '@/components/LandingPageMotion';
import { ScrollReveal } from '@/components/ScrollReveal';
import { ReactComponent as ChartOutlineIcon } from '@/assets/icons/chart-outline.svg';
import { ReactComponent as ChartLineIcon } from '@/assets/icons/chart-line-outline.svg';
import { ReactComponent as NotificationIcon } from '@/assets/icons/notification-outline.svg';
import { ReactComponent as ExpandIcon } from '@/assets/icons/expand-outline.svg';
import { ReactComponent as ProcessIcon } from '@/assets/icons/process-outline.svg';
import { ReactComponent as AiIntegrationsIcon } from '@/assets/icons/ai-integrations-outline.svg';
import { ReactComponent as TaskDoneIcon } from '@/assets/icons/task-done-outline.svg';
import { ReactComponent as DocumentsIcon } from '@/assets/icons/documents-outline.svg';
import { ReactComponent as PackageSearchIcon } from '@/assets/icons/package-search-outline.svg';
import { ReactComponent as SecureIcon } from '@/assets/icons/secure-outline.svg';
import { ReactComponent as PeopleIcon } from '@/assets/icons/people-outline.svg';
import { ReactComponent as XMarkIcon } from '@/assets/icons/x-mark-outline.svg';
import { getLangFromUrl } from '@/i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

const lang = getLangFromUrl(Astro.url);
const whoBehindSlug = lang === 'en' ? '/who-is-behind' : '/quien-esta-detras';
const servicesHref = getRelativeLocaleUrl(lang, '/services');
const whoBehindHref = getRelativeLocaleUrl(lang, whoBehindSlug);

const fillIconProps = { width: 22, height: 22, fill: '#E5C6F3' };
const strokeIconProps = { width: 22, height: 22, fill: 'none', stroke: '#E5C6F3', strokeWidth: 1.5 };

const content = lang === 'en'
  ? {
      seo: {
        title: 'TenBeltz | External AI engineering team for software companies',
        description: 'We help SaaS teams and software consultancies define, validate, and ship reliable AI systems with clear delivery criteria.',
      },
      hero: {
        eyebrow: 'AI PROJECTS WITH TECHNICAL JUDGMENT',
        title: 'Your external team',
        highlight: 'for AI engineering',
        subtitle: 'We help SaaS teams and software consultancies define, validate, and ship reliable, measurable, and profitable AI projects.',
        primaryText: 'Request proposal',
        secondaryText: 'How we work',
        microcopy: 'We reply in less than 48h',
        proofPoints: ['Clear viability', 'Evals and observability', 'Real integration', 'Cost control'],
      },
      segments: {
        title: 'We work with two kinds of software teams',
        items: [
          {
            title: 'SaaS companies',
            description: 'Teams that want to introduce AI or fix a feature that already reached production with poor reliability, high cost, or weak operating criteria.',
            bullets: ['New AI roadmap', 'Broken AI feature', 'Need for evals and observability'],
          },
          {
            title: 'Software consultancies',
            description: 'Teams that need sharper technical criteria to scope, sell, and deliver AI projects for their own clients without improvising architecture or requirements.',
            bullets: ['Pre-sales support', 'Project planning', 'Delivery foundation'],
          },
        ],
      },
      problem: {
        title: 'Most AI projects fail before production or when they finally get there',
        intro: 'The issue is rarely adding a model. The issue is knowing what to build, what data is needed, and how to operate it without hurting product, margin, or trust.',
        points: [
          'No clear viability criteria for the use case',
          'Built without enough data or evaluation coverage',
          'Costs explode when traffic grows',
          'Reliability breaks under real usage',
          'No observability, guardrails, or failure signals',
          'Projects sold without asking clients for what is needed',
        ],
      },
      value: {
        title: 'We step in where engineering judgment is actually needed',
        intro: 'TenBeltz is not an AI agency and not a generic consultancy. We define the case, structure the system, and help the team carry it into production with explicit delivery criteria.',
        promises: ['We do not sell demos', 'We do not sell hours without context'],
        capabilitiesTitle: 'We design AI systems that are:',
        capabilities: ['Decidable', 'Measurable', 'Observable', 'Maintainable'],
      },
      modalities: {
        title: 'Four ways to work with TenBeltz',
        intro: 'The offer is structured around the maturity of the project, not around arbitrary packages.',
        items: [
          {
            tag: 'Entry',
            title: 'AI Gap Analysis',
            description: 'For SaaS teams that do not know where to start or already tried something that did not go well.',
            bullets: ['Viability view', 'Recommended stack', 'Data and risk map'],
          },
          {
            tag: 'Foundation',
            title: 'AI Project Foundations',
            description: 'For consultancies or product teams that need a solid technical base before a serious build starts.',
            bullets: ['Golden set', 'Evals', 'Observability and first system design'],
          },
          {
            tag: 'Delivery',
            title: 'Production Delivery',
            description: 'For concrete projects that need to reach production and integrate cleanly with the existing product.',
            bullets: ['Implementation', 'Integration', 'Guardrails and handover'],
          },
          {
            tag: 'Partner',
            title: 'AI Partner',
            description: 'For longer relationships where we support roadmap, maintenance, cost optimization, and technical decision making.',
            bullets: ['Continuous support', 'Pre-sales help', 'Optimization and maintenance'],
          },
        ],
      },
      deliverables: {
        title: 'What clients actually walk away with',
        items: [
          'Clear viability decision',
          'Recommended architecture',
          'Tooling and stack guidance',
          'Data and dataset requirements',
          'Golden set and eval approach',
          'Observability plan',
          'Risk map and guardrails',
          'Technical roadmap',
        ],
      },
      process: {
        title: 'From fuzzy idea to operable system',
        subtitle: 'We keep the process simple: understand the context, design the system, validate with real criteria, and either ship it or support the internal team.',
        steps: [
          { title: 'Context', detail: 'We understand business constraints, product reality, and the specific use case.' },
          { title: 'System design', detail: 'We define architecture, data needs, evals, guardrails, and delivery path.' },
          { title: 'Validation', detail: 'We ground decisions in measurable criteria instead of intuition or demo theater.' },
          { title: 'Production or partner', detail: 'We either take it through delivery or stay close as an external AI engineering partner.' },
        ],
      },
      fit: {
        title: 'Who this is for',
        yesTitle: 'Good fit',
        yes: [
          'You are a SaaS or consultancy with real software delivery behind the AI ambition.',
          'You need technical judgment, not a flashy prototype.',
          'You care about reliability, observability, integration, and cost.',
          'You want a partner that can challenge scope before implementation starts.',
        ],
        noTitle: 'Not a fit',
        no: [
          'You want a cheap prototype as fast as possible.',
          'You want to add AI without a clear use case or owner.',
          'Your only buying criterion is the lowest price.',
        ],
      },
      founder: {
        eyebrow: 'Before you write',
        title: 'You work directly with Aritz',
        description: 'TenBeltz is founder-led. If you fill in the form, the reply comes from the person who will actually think through the project with you.',
        cta: 'Meet who is behind',
      },
      banner: {
        title: 'If the project matters, it is worth defining it properly from the start',
        paragraph: 'Share the context and we will tell you whether there is a strong fit and which way of working makes sense.',
        button: 'Request proposal',
      },
    }
  : {
      seo: {
        title: 'TenBeltz | Equipo externo de ingenieria IA para empresas de software',
        description: 'Ayudamos a empresas SaaS y consultoras de software a definir, validar y llevar a produccion sistemas de IA con criterio tecnico claro.',
      },
      hero: {
        eyebrow: 'PROYECTOS DE IA CON CRITERIO TECNICO',
        title: 'Tu equipo externo',
        highlight: 'de ingenieria IA',
        subtitle: 'Ayudamos a empresas SaaS y consultoras de software a definir, validar y llevar a produccion proyectos de IA fiables, medibles y rentables.',
        primaryText: 'Solicitar propuesta',
        secondaryText: 'Como trabajamos',
        microcopy: 'Respondemos en menos de 48h',
        proofPoints: ['Viabilidad clara', 'Evals y observabilidad', 'Integracion real', 'Control de costes'],
      },
      segments: {
        title: 'Trabajamos con dos tipos de equipos de software',
        items: [
          {
            title: 'Empresas SaaS',
            description: 'Equipos que quieren introducir IA o corregir una feature que ya llego a produccion con poca fiabilidad, mucho coste o criterios operativos debiles.',
            bullets: ['Nueva iniciativa de IA', 'Feature de IA con problemas', 'Necesidad de evals y observabilidad'],
          },
          {
            title: 'Consultoras de software',
            description: 'Equipos que necesitan mejor criterio tecnico para definir, vender y ejecutar proyectos de IA para sus propios clientes sin improvisar arquitectura ni requisitos.',
            bullets: ['Soporte en preventa', 'Planificacion del proyecto', 'Base para delivery'],
          },
        ],
      },
      problem: {
        title: 'La mayoria de proyectos de IA fallan antes de produccion o cuando por fin llegan a ella',
        intro: 'El problema rara vez es enchufar un modelo. El problema es saber que construir, que datos hacen falta y como operarlo sin dañar producto, margen ni confianza.',
        points: [
          'No hay criterio claro para decidir si el caso de uso merece la pena',
          'Se construye sin suficientes datos ni evaluacion',
          'Los costes se disparan al crecer el trafico',
          'La fiabilidad se rompe con uso real',
          'No hay observabilidad, guardrails ni senales de fallo',
          'Se vende el proyecto sin pedir al cliente lo necesario',
        ],
      },
      value: {
        title: 'Entramos donde de verdad hace falta criterio de ingenieria',
        intro: 'TenBeltz no es una agencia de IA ni una consultora generica. Definimos el caso, estructuramos el sistema y ayudamos al equipo a llevarlo a produccion con criterios de entrega explicitos.',
        promises: ['No vendemos demos', 'No vendemos horas sin contexto'],
        capabilitiesTitle: 'Disenamos sistemas de IA que son:',
        capabilities: ['Decidibles', 'Medibles', 'Observables', 'Mantenibles'],
      },
      modalities: {
        title: 'Cuatro formas de trabajar con TenBeltz',
        intro: 'La oferta se organiza segun la madurez del proyecto, no como paquetes arbitrarios.',
        items: [
          {
            tag: 'Entrada',
            title: 'AI Gap Analysis',
            description: 'Para equipos SaaS que no saben por donde empezar o que ya probaron algo y no salio bien.',
            bullets: ['Vision de viabilidad', 'Stack recomendado', 'Mapa de datos y riesgos'],
          },
          {
            tag: 'Base',
            title: 'AI Project Foundations',
            description: 'Para consultoras o equipos de producto que necesitan una base tecnica solida antes de construir en serio.',
            bullets: ['Golden set', 'Evals', 'Observabilidad y primer diseno de sistema'],
          },
          {
            tag: 'Delivery',
            title: 'Production Delivery',
            description: 'Para proyectos concretos que deben llegar a produccion e integrarse bien con el producto existente.',
            bullets: ['Implementacion', 'Integracion', 'Guardrails y handover'],
          },
          {
            tag: 'Partner',
            title: 'AI Partner',
            description: 'Para relaciones mas largas donde acompanamos roadmap, mantenimiento, optimizacion de costes y decisiones tecnicas.',
            bullets: ['Acompanamiento continuo', 'Ayuda en preventa', 'Optimizacion y mantenimiento'],
          },
        ],
      },
      deliverables: {
        title: 'Que se lleva realmente el cliente',
        items: [
          'Decision clara de viabilidad',
          'Arquitectura recomendada',
          'Guia de stack y tooling',
          'Requisitos de datos y datasets',
          'Golden set y enfoque de evals',
          'Plan de observabilidad',
          'Mapa de riesgos y guardrails',
          'Roadmap tecnico',
        ],
      },
      process: {
        title: 'De idea difusa a sistema operable',
        subtitle: 'Mantenemos el proceso simple: entender el contexto, disenar el sistema, validar con criterios reales y llevarlo a produccion o acompanar al equipo.',
        steps: [
          { title: 'Contexto', detail: 'Entendemos restricciones de negocio, realidad de producto y caso de uso concreto.' },
          { title: 'Diseno de sistema', detail: 'Definimos arquitectura, necesidades de datos, evals, guardrails y camino de entrega.' },
          { title: 'Validacion', detail: 'Aterrizamos decisiones con criterios medibles en lugar de intuicion o teatro de demo.' },
          { title: 'Produccion o partner', detail: 'O lo llevamos hasta delivery o nos quedamos cerca como equipo externo de ingenieria IA.' },
        ],
      },
      fit: {
        title: 'Para quien encaja',
        yesTitle: 'Encaja bien',
        yes: [
          'Eres un SaaS o una consultora con capacidad real de delivery de software.',
          'Necesitas criterio tecnico, no un prototipo vistoso.',
          'Te importan fiabilidad, observabilidad, integracion y costes.',
          'Quieres un partner que cuestione el alcance antes de empezar a construir.',
        ],
        noTitle: 'No encaja',
        no: [
          'Buscas un prototipo barato lo antes posible.',
          'Quieres meter IA sin un caso de uso ni un owner claros.',
          'Tu unico criterio de compra es el precio mas bajo.',
        ],
      },
      founder: {
        eyebrow: 'Antes de escribir',
        title: 'Trabajas directamente con Aritz',
        description: 'TenBeltz es founder-led. Si rellenas el formulario, responde la persona que realmente va a pensar el proyecto contigo.',
        cta: 'Conoce quien esta detras',
      },
      banner: {
        title: 'Si el proyecto importa, conviene definirlo bien desde el principio',
        paragraph: 'Comparte el contexto y te diremos si hay encaje claro y que forma de trabajo tiene sentido.',
        button: 'Solicitar propuesta',
      },
    };

const segmentCards = [
  { icon: AiIntegrationsIcon, iconProps: fillIconProps, ...content.segments.items[0] },
  { icon: PeopleIcon, iconProps: strokeIconProps, ...content.segments.items[1] },
];

const problemCards = [
  { icon: PackageSearchIcon, iconProps: strokeIconProps, text: content.problem.points[0] },
  { icon: DocumentsIcon, iconProps: strokeIconProps, text: content.problem.points[1] },
  { icon: ChartOutlineIcon, iconProps: fillIconProps, text: content.problem.points[2] },
  { icon: NotificationIcon, iconProps: strokeIconProps, text: content.problem.points[3] },
  { icon: SecureIcon, iconProps: strokeIconProps, text: content.problem.points[4] },
  { icon: ProcessIcon, iconProps: fillIconProps, text: content.problem.points[5] },
];

const capabilityCards = [
  { icon: TaskDoneIcon, iconProps: strokeIconProps, text: content.value.capabilities[0] },
  { icon: ChartLineIcon, iconProps: fillIconProps, text: content.value.capabilities[1] },
  { icon: NotificationIcon, iconProps: strokeIconProps, text: content.value.capabilities[2] },
  { icon: ExpandIcon, iconProps: strokeIconProps, text: content.value.capabilities[3] },
];

const modalityIcons = [DocumentsIcon, PackageSearchIcon, SecureIcon, PeopleIcon];
const modalityCards = content.modalities.items.map((item, index) => ({
  ...item,
  icon: modalityIcons[index],
  iconProps: strokeIconProps,
}));

const deliverableIcons = [DocumentsIcon, ProcessIcon, AiIntegrationsIcon, PackageSearchIcon, TaskDoneIcon, NotificationIcon, SecureIcon, ChartLineIcon];
const deliverableCards = content.deliverables.items.map((item, index) => ({
  text: item,
  icon: deliverableIcons[index],
  iconProps: index === 1 || index === 2 ? fillIconProps : strokeIconProps,
}));

const processIcons = [DocumentsIcon, ProcessIcon, TaskDoneIcon, ChartLineIcon];
const processCards = content.process.steps.map((step, index) => ({
  ...step,
  icon: processIcons[index],
  iconProps: index === 1 ? fillIconProps : strokeIconProps,
}));
---

<Layout
  title={content.seo.title}
  description={content.seo.description}
  canonical="https://tenbeltz.com"
>
  <Header />
  <main class="relative z-10 flex flex-col flex-1 overflow-x-hidden">
    <HomeHero
      eyebrow={content.hero.eyebrow}
      title={content.hero.title}
      highlight={content.hero.highlight}
      subtitle={content.hero.subtitle}
      primaryHref="#contact-section"
      primaryText={content.hero.primaryText}
      secondaryHref="#como-trabajamos"
      secondaryText={content.hero.secondaryText}
      microcopy={content.hero.microcopy}
      proofPoints={content.hero.proofPoints}
    />

    <section class="relative text-white section-shell">
      <div class="max-w-screen-xl px-4 py-20 mx-auto lg:px-16 lg:py-24">
        <ScrollReveal client:visible>
          <div class="max-w-3xl">
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-pheromone-light/80">TenBeltz</p>
            <h2 class="mt-3 text-4xl font-bold lg:text-5xl">{content.segments.title}</h2>
          </div>
        </ScrollReveal>
        <div class="grid grid-cols-1 gap-6 mt-10 lg:grid-cols-2">
          {segmentCards.map((item, index) => (
            <ScrollReveal client:visible delay={index * 120}>
              <div class="flex flex-col h-full gap-5 rounded-2xl border border-pheromone-purple/25 bg-[#0B0122CC]/80 px-6 py-7 shadow-[0_0_25px_rgba(3,7,18,0.35)] backdrop-blur-sm">
                <span class="flex h-11 w-11 items-center justify-center rounded-full bg-pheromone-purple/20">
                  <item.icon {...item.iconProps} />
                </span>
                <div class="flex flex-col gap-3">
                  <h3 class="text-2xl font-semibold">{item.title}</h3>
                  <p class="text-slate-300">{item.description}</p>
                </div>
                <ul class="flex flex-col gap-2 text-sm text-slate-300">
                  {item.bullets.map((bullet) => <li>• {bullet}</li>)}
                </ul>
              </div>
            </ScrollReveal>
          ))}
        </div>
      </div>
    </section>

    <section id="problemas" class="relative text-white bg-grid">
      <div class="pointer-events-none absolute -top-16 right-0 h-64 w-64 rounded-full bg-pheromone-purple/20 blur-3xl"></div>
      <div class="max-w-screen-xl px-4 py-20 mx-auto lg:px-16 lg:py-24">
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-[1fr_1.2fr]">
          <ScrollReveal client:visible>
            <div class="max-w-xl">
              <p class="text-sm font-semibold uppercase tracking-[0.28em] text-pheromone-light/80">Problem</p>
              <h2 class="mt-3 text-4xl font-bold lg:text-5xl">{content.problem.title}</h2>
              <p class="mt-5 text-lg text-slate-300">{content.problem.intro}</p>
            </div>
          </ScrollReveal>
          <ScrollReveal client:visible>
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
              {problemCards.map((item) => (
                <div class="flex gap-4 rounded-2xl border border-pheromone-purple/20 bg-[#0B0122CC]/80 px-5 py-5 backdrop-blur-sm">
                  <span class="mt-0.5 flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-full bg-pheromone-purple/20">
                    <item.icon {...item.iconProps} />
                  </span>
                  <p class="text-slate-200">{item.text}</p>
                </div>
              ))}
            </div>
          </ScrollReveal>
        </div>
      </div>
    </section>

    <section class="relative text-white">
      <div class="pointer-events-none absolute -bottom-10 left-0 h-64 w-64 rounded-full bg-pheromone-purple/20 blur-3xl"></div>
      <div class="max-w-screen-xl px-4 py-20 mx-auto lg:px-16 lg:py-24">
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-[1fr_1.05fr]">
          <ScrollReveal client:visible>
            <div class="max-w-xl">
              <p class="text-sm font-semibold uppercase tracking-[0.28em] text-pheromone-light/80">Value</p>
              <h2 class="mt-3 text-4xl font-bold lg:text-5xl">{content.value.title}</h2>
              <p class="mt-5 text-lg text-slate-300">{content.value.intro}</p>
            </div>
          </ScrollReveal>
          <ScrollReveal client:visible>
            <div class="flex flex-col gap-4">
              {content.value.promises.map((promise) => (
                <div class="flex items-center gap-3 rounded-xl border border-slate-700/60 bg-[#12011F]/85 px-5 py-4">
                  <span class="flex h-10 w-10 items-center justify-center rounded-full bg-berry-blackmail/60">
                    <XMarkIcon width="20" height="20" fill="none" stroke="#E5C6F3" strokeWidth="1.5" />
                  </span>
                  <p class="text-lg font-semibold text-white">{promise}</p>
                </div>
              ))}
              <div class="rounded-2xl border border-pheromone-purple/30 bg-gradient-to-br from-[#16002E] to-[#240044] px-5 py-5 backdrop-blur-sm">
                <p class="text-lg font-semibold text-white">{content.value.capabilitiesTitle}</p>
                <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
                  {capabilityCards.map((item) => (
                    <div class="flex items-center gap-3 rounded-lg border border-slate-700/40 bg-[#14002A]/70 px-4 py-3 backdrop-blur-sm">
                      <span class="flex h-9 w-9 items-center justify-center rounded-full bg-pheromone-purple/20">
                        <item.icon {...item.iconProps} width="18" height="18" />
                      </span>
                      <p class="text-slate-200">{item.text}</p>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </ScrollReveal>
        </div>
      </div>
    </section>

    <section id="que-hacemos" class="relative text-white bg-grid">
      <div class="max-w-screen-xl px-4 py-20 mx-auto lg:px-16 lg:py-24">
        <ScrollReveal client:visible>
          <div class="max-w-3xl">
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-pheromone-light/80">Ways of working</p>
            <h2 class="mt-3 text-4xl font-bold lg:text-5xl">{content.modalities.title}</h2>
            <p class="mt-5 text-lg text-slate-300">{content.modalities.intro}</p>
          </div>
        </ScrollReveal>
        <div class="grid grid-cols-1 gap-5 mt-10 md:grid-cols-2">
          {modalityCards.map((item, index) => (
            <ScrollReveal client:visible delay={index * 90}>
              <div data-tilt-card class="tilt-card rounded-2xl h-full">
                <div data-tilt-inner class="tilt-card__inner flex h-full flex-col gap-5 rounded-2xl border border-pheromone-purple/25 bg-[#0B0122CC]/80 px-6 py-7 shadow-[0_0_25px_rgba(3,7,18,0.35)] backdrop-blur-sm">
                  <div class="flex items-center justify-between gap-4">
                    <span class="inline-flex rounded-full border border-pheromone-purple/40 bg-pheromone-purple/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-pheromone-light">
                      {item.tag}
                    </span>
                    <span class="flex h-11 w-11 items-center justify-center rounded-full bg-pheromone-purple/20">
                      <item.icon {...item.iconProps} />
                    </span>
                  </div>
                  <div class="flex flex-col gap-3">
                    <h3 class="text-2xl font-semibold">{item.title}</h3>
                    <p class="text-slate-300">{item.description}</p>
                  </div>
                  <ul class="mt-auto flex flex-col gap-2 text-sm text-slate-300">
                    {item.bullets.map((bullet) => <li>• {bullet}</li>)}
                  </ul>
                </div>
              </div>
            </ScrollReveal>
          ))}
        </div>
        <ScrollReveal client:visible>
          <div class="mt-10">
            <a href={servicesHref} class="inline-flex items-center justify-center rounded-xl border border-white/12 bg-white/[0.04] px-6 py-3 text-base font-semibold text-white/90 backdrop-blur-md transition-colors duration-300 hover:border-white/25 hover:bg-white/[0.08]">
              {lang === 'en' ? 'See the service structure' : 'Ver la estructura de servicios'}
            </a>
          </div>
        </ScrollReveal>
      </div>
    </section>

    <section class="relative text-white">
      <div class="max-w-screen-xl px-4 py-20 mx-auto lg:px-16 lg:py-24">
        <ScrollReveal client:visible>
          <div class="max-w-3xl">
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-pheromone-light/80">Deliverables</p>
            <h2 class="mt-3 text-4xl font-bold lg:text-5xl">{content.deliverables.title}</h2>
          </div>
        </ScrollReveal>
        <div class="grid grid-cols-1 gap-4 mt-10 sm:grid-cols-2 lg:grid-cols-4">
          {deliverableCards.map((item, index) => (
            <ScrollReveal client:visible delay={index * 60}>
              <div class="flex h-full flex-col gap-4 rounded-2xl border border-pheromone-purple/20 bg-[#0B0122CC]/80 px-5 py-5 backdrop-blur-sm">
                <span class="flex h-11 w-11 items-center justify-center rounded-full bg-pheromone-purple/20">
                  <item.icon {...item.iconProps} />
                </span>
                <p class="text-slate-200">{item.text}</p>
              </div>
            </ScrollReveal>
          ))}
        </div>
      </div>
    </section>

    <section id="como-trabajamos" class="relative text-white bg-grid">
      <div class="max-w-screen-xl px-4 py-20 mx-auto lg:px-16 lg:py-24">
        <ScrollReveal client:visible>
          <div class="max-w-3xl">
            <p class="text-sm font-semibold uppercase tracking-[0.28em] text-pheromone-light/80">Process</p>
            <h2 class="mt-3 text-4xl font-bold lg:text-5xl">{content.process.title}</h2>
            <p class="mt-5 text-lg text-slate-300">{content.process.subtitle}</p>
          </div>
        </ScrollReveal>
        <div class="grid grid-cols-1 gap-5 mt-10 md:grid-cols-2 xl:grid-cols-4">
          {processCards.map((step, index) => (
            <ScrollReveal client:visible delay={index * 80}>
              <div class="flex h-full flex-col gap-4 rounded-2xl border border-pheromone-purple/20 bg-[#0B0122CC]/80 px-5 py-6 backdrop-blur-sm">
                <div class="flex items-center justify-between gap-4">
                  <span class="flex h-11 w-11 items-center justify-center rounded-full bg-pheromone-purple/20">
                    <step.icon {...step.iconProps} />
                  </span>
                  <span class="text-xs font-semibold uppercase tracking-[0.28em] text-pheromone-light/80">0{index + 1}</span>
                </div>
                <p class="text-xl font-semibold text-white">{step.title}</p>
                <p class="text-slate-300">{step.detail}</p>
              </div>
            </ScrollReveal>
          ))}
        </div>
      </div>
    </section>

    <section id="para-quien" class="relative text-white">
      <div class="max-w-screen-xl px-4 py-20 mx-auto lg:px-16 lg:py-24">
        <ScrollReveal client:visible>
          <h2 class="text-4xl font-bold lg:text-5xl">{content.fit.title}</h2>
        </ScrollReveal>
        <div class="grid grid-cols-1 gap-6 mt-10 lg:grid-cols-2">
          <ScrollReveal client:visible>
            <div class="flex h-full flex-col gap-4 rounded-2xl bg-gradient-to-br from-[#110126] to-[#1C0434] px-6 py-7 border border-pheromone-purple/35">
              <span class="flex h-11 w-11 items-center justify-center rounded-full bg-pheromone-purple/20">
                <PeopleIcon width="22" height="22" fill="none" stroke="#E5C6F3" strokeWidth="1.5" />
              </span>
              <h3 class="text-2xl font-semibold">{content.fit.yesTitle}</h3>
              <ul class="flex flex-col gap-y-2 text-slate-300">
                {content.fit.yes.map((item) => <li>• {item}</li>)}
              </ul>
            </div>
          </ScrollReveal>
          <ScrollReveal client:visible>
            <div class="flex h-full flex-col gap-4 rounded-2xl bg-gradient-to-br from-[#1A0032] to-[#2A0A44] px-6 py-7 border border-pheromone-purple/35">
              <span class="flex h-11 w-11 items-center justify-center rounded-full bg-pheromone-purple/20">
                <XMarkIcon width="22" height="22" fill="none" stroke="#E5C6F3" strokeWidth="1.5" />
              </span>
              <h3 class="text-2xl font-semibold">{content.fit.noTitle}</h3>
              <ul class="flex flex-col gap-y-2 text-slate-300">
                {content.fit.no.map((item) => <li>• {item}</li>)}
              </ul>
            </div>
          </ScrollReveal>
        </div>
      </div>
    </section>

    <Banner
      title={content.banner.title}
      paragraph={content.banner.paragraph}
      buttonText={content.banner.button}
      buttonHref="#contact-section"
    />

    <section class="relative text-white">
      <div class="max-w-screen-xl px-4 py-14 mx-auto lg:px-16 lg:py-16">
        <ScrollReveal client:visible>
          <a
            href={whoBehindHref}
            class="group flex flex-col items-start gap-5 rounded-2xl border border-pheromone-purple/25 bg-[#0B0122CC]/80 px-6 py-6 shadow-[0_0_25px_rgba(3,7,18,0.35)] backdrop-blur-sm transition-all hover:border-pheromone-purple/60 hover:bg-[#130130CC]/80 sm:flex-row sm:items-center sm:gap-6"
          >
            <span class="relative flex-shrink-0">
              <span aria-hidden="true" class="absolute inset-0 -m-1 rounded-full bg-gradient-to-br from-pheromone-light/50 via-pheromone-purple/30 to-transparent blur-md"></span>
              <span class="relative block rounded-full p-[2px] bg-gradient-to-br from-pheromone-light via-pheromone-purple to-sapphire-siren">
                <img
                  src="/images/team/aritz.webp"
                  alt="Aritz Jaber Lopes"
                  width="72"
                  height="72"
                  loading="lazy"
                  decoding="async"
                  class="block h-16 w-16 rounded-full object-cover bg-obsidian-shard"
                />
              </span>
            </span>
            <div class="flex flex-1 flex-col gap-y-1">
              <p class="text-xs font-semibold uppercase tracking-[0.28em] text-pheromone-light/80">
                {content.founder.eyebrow}
              </p>
              <p class="text-xl font-semibold text-white">{content.founder.title}</p>
              <p class="text-base text-slate-300">{content.founder.description}</p>
            </div>
            <span class="inline-flex items-center gap-x-2 whitespace-nowrap text-sm font-semibold text-pheromone-light transition-colors group-hover:text-white">
              {content.founder.cta}
              <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
            </span>
          </a>
        </ScrollReveal>
      </div>
    </section>

    <Contact />
    <LandingPageMotion client:load />
  </main>
  <Footer />
</Layout>
