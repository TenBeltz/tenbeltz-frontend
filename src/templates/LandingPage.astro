      <div class="pointer-events-none absolute left-1/4 top-20 h-80 w-80 -translate-x-1/2 rounded-full bg-pheromone-purple/15 blur-3xl"></div>
      <div class="pointer-events-none absolute bottom-20 right-1/4 h-96 w-96 translate-x-1/3 rounded-full bg-sapphire-siren/10 blur-3xl"></div>

      <div class="method-stage relative mx-auto flex max-w-screen-xl flex-col justify-center px-4 py-16 lg:min-h-screen lg:px-16 lg:py-20">
        <div class="mx-auto max-w-3xl text-center">
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.32em] text-pheromone-light">Process</p>
          <h2 class="mt-4 text-4xl font-bold leading-[1.05] tracking-tight lg:text-6xl">
            {content.process.title}
