---
interface Props {
	title: string
	description: string
	canonical?: string
	image?: string
	lang?: string
	noindex?: boolean
}

const {
	title,
	description,
	canonical,
	image,
	lang = 'es',
	noindex = false,
} = Astro.props as Props

// Dedicated OG image per locale (1200x630). Social crawlers need an absolute URL.
const defaultOgPath = lang === 'en' ? '/og/og-en.png' : '/og/og-es.png'
const ogImage = new URL(image ?? defaultOgPath, Astro.site)
const isDefaultOgImage = !image

const determineCanonicalURL = () => {
	if (Astro.url.host.includes("localhost")) return `http://localhost:4321${Astro.url.pathname}`
	return canonical || Astro.url.pathname;
}

const canonicalURL = new URL(determineCanonicalURL(), Astro.site)

// Build hreflang alternate URLs from the canonical
const canonicalPath = canonicalURL.pathname
const isEnglish = canonicalPath.startsWith('/en/') || canonicalPath === '/en'
const basePath = isEnglish ? canonicalPath.replace(/^\/en/, '') || '/' : canonicalPath

// Slugs that differ between locales. Key is the stripped path (from either locale); value is the per-locale slug.
const localizedSlugMap: Record<string, { es: string; en: string }> = {
	'/quien-esta-detras': { es: '/quien-esta-detras', en: '/who-is-behind' },
	'/who-is-behind': { es: '/quien-esta-detras', en: '/who-is-behind' },
	'/casos': { es: '/casos', en: '/case-studies' },
	'/case-studies': { es: '/casos', en: '/case-studies' },
}
const mapped = localizedSlugMap[basePath.replace(/\/$/, '')]
const esPath = mapped ? mapped.es : basePath
const enPath = mapped ? mapped.en : basePath
const esURL = new URL(esPath, Astro.site)
const enURL = new URL(`/en${enPath === '/' ? '' : enPath}`, Astro.site)

const ogLocale = lang === 'en' ? 'en_US' : 'es_ES'
const ogLocaleAlternate = lang === 'en' ? 'es_ES' : 'en_US'

// JSON-LD (schema.org): Organization + founder Person
const organizationLogo = new URL('/favicon/web-app-manifest-512x512.png', Astro.site).href
const jsonLd = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'Organization',
			'@id': 'https://tenbeltz.com/#organization',
			name: 'TenBeltz',
			legalName: 'Beltz Dev SL',
			vatID: 'B21697719',
			url: 'https://tenbeltz.com',
			logo: organizationLogo,
			email: 'hello@tenbeltz.com',
			telephone: '+34640520819',
			address: {
				'@type': 'PostalAddress',
				streetAddress: 'Avenida Elexalde 8',
				postalCode: '48940',
				addressLocality: 'Leioa',
				addressRegion: 'Bizkaia',
				addressCountry: 'ES',
			},
			sameAs: [
				'https://www.linkedin.com/company/tenbeltz/',
				'https://www.instagram.com/tenbeltz/',
			],
			founder: { '@id': 'https://tenbeltz.com/#aritz' },
		},
		{
			'@type': 'Person',
			'@id': 'https://tenbeltz.com/#aritz',
			name: 'Aritz Jaber Lopes',
			jobTitle: 'Cofundador y líder técnico',
			worksFor: { '@id': 'https://tenbeltz.com/#organization' },
			sameAs: [
				'https://www.linkedin.com/in/aritzjl/',
				'https://github.com/aritzjl',
				'https://aritzjaber.com',
			],
		},
	],
}
---

<title>{title}</title>

<meta charset="UTF-8" />
<meta name="description" content={description} />

<link rel="canonical" href={canonicalURL} />
<link rel="alternate" hreflang="es" href={esURL} />
<link rel="alternate" hreflang="en" href={enURL} />
<link rel="alternate" hreflang="x-default" href={esURL} />
<meta name="viewport" content="width=device-width" />
<meta name="theme-color" content="#02010A" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@TenBeltz" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<meta property="og:image" content={ogImage} />
{isDefaultOgImage && <meta property="og:image:width" content="1200" />}
{isDefaultOgImage && <meta property="og:image:height" content="630" />}
{isDefaultOgImage && <meta property="og:image:type" content="image/png" />}
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={Astro.url} />
<meta property="og:site_name" content="TenBeltz" />
<meta property="og:type" content="website" />
<meta property="og:locale" content={ogLocale} />
<meta property="og:locale:alternate" content={ogLocaleAlternate} />

<meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow'} />
<meta name="googlebot" content={noindex ? 'noindex, follow' : 'index, follow'} />

<link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg">
<link rel="icon" type="image/png" sizes="96x96" href="/favicon/favicon-96x96.png">
<link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
<link rel="manifest" href="/favicon/site.webmanifest">
<link rel="shortcut icon" href="/favicon/favicon.ico">
<meta name="apple-mobile-web-app-title" content="TenBeltz">

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
