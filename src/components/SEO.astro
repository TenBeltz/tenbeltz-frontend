---
interface Props {
	title: string
	description: string
	canonical?: string
	image?: string
	lang?: string
	noindex?: boolean
}

const {
	title,
	description,
	canonical,
	image,
	lang = 'es',
	noindex = false,
} = Astro.props as Props

// Dedicated OG image per locale (1200x630). Social crawlers need an absolute URL.
const defaultOgPath = lang === 'en' ? '/og/og-en.png' : '/og/og-es.png'
const ogImage = new URL(image ?? defaultOgPath, Astro.site)
const isDefaultOgImage = !image

const determineCanonicalURL = () => {
	if (Astro.url.host.includes("localhost")) return `http://localhost:4321${Astro.url.pathname}`
	return canonical || Astro.url.pathname;
}

const canonicalURL = new URL(determineCanonicalURL(), Astro.site)

// Build hreflang alternate URLs from the canonical
const canonicalPath = canonicalURL.pathname
const isEnglish = canonicalPath.startsWith('/en/') || canonicalPath === '/en'
const basePath = isEnglish ? canonicalPath.replace(/^\/en/, '') || '/' : canonicalPath

// Slugs that differ between locales. Key is the stripped path (from either locale); value is the per-locale slug.
const localizedSlugMap: Record<string, { es: string; en: string }> = {
	'/quien-esta-detras': { es: '/quien-esta-detras', en: '/who-is-behind' },
	'/who-is-behind': { es: '/quien-esta-detras', en: '/who-is-behind' },
	'/casos': { es: '/casos', en: '/case-studies' },
	'/case-studies': { es: '/casos', en: '/case-studies' },
}
const mapped = localizedSlugMap[basePath.replace(/\/$/, '')]
const esPath = mapped ? mapped.es : basePath
const enPath = mapped ? mapped.en : basePath
const esURL = new URL(esPath, Astro.site)
const enURL = new URL(`/en${enPath === '/' ? '' : enPath}`, Astro.site)

const ogLocale = lang === 'en' ? 'en_US' : 'es_ES'
const ogLocaleAlternate = lang === 'en' ? 'es_ES' : 'en_US'

// Page identity is derived from the path only — no extra props for templates to pass.
// `routeKey` normalises both locales onto the Spanish slug so one map serves es and en.
const routeKey = (mapped ? mapped.es : basePath.replace(/\/$/, '')) || '/'
const isHome = routeKey === '/'

// Absolute URL for a route in the *current* locale. Mirrors the hreflang builder above:
// the English home page is `/en`, not `/en/`.
const localeHref = (path: string) => {
	const prefix = lang === 'en' ? '/en' : ''
	const suffix = path === '/' ? '' : path
	return new URL(`${prefix}${suffix}` || '/', Astro.site).href
}

// Breadcrumb labels mirror the nav labels in Header.astro. They live there as a local
// const that cannot be imported, so they are restated rather than wired through props.
const routeNames: Record<string, { es: string; en: string }> = {
	'/': { es: 'Inicio', en: 'Home' },
	'/services': { es: 'Servicios', en: 'Services' },
	'/casos': { es: 'Casos', en: 'Case studies' },
	'/quien-esta-detras': { es: 'Quién está detrás', en: 'Who is behind' },
	'/politicas': { es: 'Política de uso y privacidad', en: 'Terms of Use and Privacy' },
}
const routeName = (key: string, fallback: string) => {
	const entry = routeNames[key]
	if (!entry) return fallback
	return lang === 'en' ? entry.en : entry.es
}

const homeName = routeName('/', 'TenBeltz')
const currentPageName = routeName(routeKey, title)
const currentPageUrl = canonicalURL.href
const breadcrumbId = `${currentPageUrl}#breadcrumb`
const servicesUrl = localeHref('/services')
const isProfilePage = routeKey === '/quien-esta-detras'

// JSON-LD (schema.org): Organization + founder Person
const organizationLogo = new URL('/favicon/web-app-manifest-512x512.png', Astro.site).href

const orgDescription = lang === 'en'
	? 'External AI engineering team for software companies. Helps SaaS products and software consultancies define, validate and ship AI systems to production with explicit delivery criteria.'
	: 'Equipo externo de ingeniería de IA para empresas de software. Ayuda a productos SaaS y consultoras a definir, validar y llevar a producción sistemas de IA con criterios de entrega explícitos.'

// Topics the org claims expertise in. Present in body copy but previously absent from the
// entity graph, which is what answer engines read to decide "who is an authority on X".
const knowsAbout = [
	'Artificial intelligence engineering',
	'Large language model applications',
	'Retrieval-augmented generation',
	'Multi-agent systems',
	'LLM evaluation',
	'AI observability',
	'AI cost optimization',
	'Machine learning in production',
]

// `id` matches the `id="service-${id}"` anchors rendered by ServicesSection.astro, so each
// Service node is deep-linkable to its own card on the services page.
const serviceCatalog = [
	{ id: 'gap-analysis', name: 'AI Gap Analysis', es: 'Diagnóstico para decidir si merece la pena construir el sistema, con roadmap técnico.', en: 'Diagnostic to decide whether the system is worth building, with a technical roadmap.' },
	{ id: 'foundations', name: 'AI Project Foundations', es: 'Bases técnicas del proyecto: arquitectura, stack y criterios de entrega.', en: 'Technical foundations: architecture, stack and delivery criteria.' },
	{ id: 'agent-mvp', name: 'Agent MVP', es: 'Primer agente en funcionamiento sobre un caso acotado y medible.', en: 'First working agent on a scoped, measurable use case.' },
	{ id: 'production-delivery', name: 'Production Delivery', es: 'Entrega en producción con fiabilidad medible, observabilidad y control de coste.', en: 'Production delivery with measurable reliability, observability and cost control.' },
]

// Breadcrumbs on every page except the two home pages, where a one-item trail adds nothing.
const breadcrumbNode = isHome
	? null
	: {
			'@type': 'BreadcrumbList',
			'@id': breadcrumbId,
			itemListElement: [
				{ '@type': 'ListItem', position: 1, name: homeName, item: localeHref('/') },
				{ '@type': 'ListItem', position: 2, name: currentPageName, item: currentPageUrl },
			],
		}

// ProfilePage is the schema.org type for a page about a single person, which is exactly
// what /quien-esta-detras is. mainEntity points at the Person already in this graph.
const profilePageNode = isProfilePage
	? {
			'@type': 'ProfilePage',
			'@id': `${currentPageUrl}#profilepage`,
			url: currentPageUrl,
			name: title,
			description,
			inLanguage: lang === 'en' ? 'en' : 'es',
			mainEntity: { '@id': 'https://tenbeltz.com/#aritz' },
			about: { '@id': 'https://tenbeltz.com/#aritz' },
			...(breadcrumbNode ? { breadcrumb: { '@id': breadcrumbId } } : {}),
		}
	: null

const jsonLd = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': ['Organization', 'ProfessionalService', 'LocalBusiness'],
			'@id': 'https://tenbeltz.com/#organization',
			name: 'TenBeltz',
			description: orgDescription,
			knowsAbout,
			areaServed: { '@type': 'Country', name: 'Spain' },
			hasOfferCatalog: {
				'@type': 'OfferCatalog',
				name: lang === 'en' ? 'AI engineering services' : 'Servicios de ingeniería de IA',
				itemListElement: serviceCatalog.map((service) => ({
					'@type': 'Offer',
					itemOffered: {
						'@type': 'Service',
						name: service.name,
						description: lang === 'en' ? service.en : service.es,
						url: `${servicesUrl}#service-${service.id}`,
						provider: { '@id': 'https://tenbeltz.com/#organization' },
					},
				})),
			},
			legalName: 'Beltz Dev SL',
			vatID: 'B21697719',
			url: 'https://tenbeltz.com',
			logo: organizationLogo,
			// LocalBusiness expects an image; reuse the logo rather than invent an asset.
			image: organizationLogo,
			email: 'hello@tenbeltz.com',
			telephone: '+34640520819',
			address: {
				'@type': 'PostalAddress',
				streetAddress: 'Avenida Elexalde 8',
				postalCode: '48940',
				addressLocality: 'Leioa',
				addressRegion: 'Bizkaia',
				addressCountry: 'ES',
			},
			sameAs: [
				'https://www.linkedin.com/company/tenbeltz/',
				'https://www.instagram.com/tenbeltz/',
			],
			founder: { '@id': 'https://tenbeltz.com/#aritz' },
		},
		{
			'@type': 'Person',
			'@id': 'https://tenbeltz.com/#aritz',
			name: 'Aritz Jaber Lopes',
			jobTitle: lang === 'en' ? 'Co-founder and technical lead' : 'Cofundador y líder técnico',
			worksFor: { '@id': 'https://tenbeltz.com/#organization' },
			knowsAbout,
			sameAs: [
				'https://www.linkedin.com/in/aritzjl/',
				'https://github.com/aritzjl',
				'https://aritzjaber.com',
			],
		},
		...(breadcrumbNode ? [breadcrumbNode] : []),
		...(profilePageNode ? [profilePageNode] : []),
	],
}
---

<title>{title}</title>

<meta charset="UTF-8" />
<meta name="description" content={description} />

<link rel="canonical" href={canonicalURL} />
<link rel="alternate" hreflang="es" href={esURL} />
<link rel="alternate" hreflang="en" href={enURL} />
<link rel="alternate" hreflang="x-default" href={esURL} />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="theme-color" content="#02010A" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@TenBeltz" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<meta property="og:image" content={ogImage} />
{isDefaultOgImage && <meta property="og:image:width" content="1200" />}
{isDefaultOgImage && <meta property="og:image:height" content="630" />}
{isDefaultOgImage && <meta property="og:image:type" content="image/png" />}
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={Astro.url} />
<meta property="og:site_name" content="TenBeltz" />
<meta property="og:type" content="website" />
<meta property="og:locale" content={ogLocale} />
<meta property="og:locale:alternate" content={ogLocaleAlternate} />

<meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow'} />
<meta name="googlebot" content={noindex ? 'noindex, follow' : 'index, follow'} />

<link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg">
<link rel="icon" type="image/png" sizes="96x96" href="/favicon/favicon-96x96.png">
<link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
<link rel="manifest" href="/favicon/site.webmanifest">
<link rel="shortcut icon" href="/favicon/favicon.ico">
<meta name="apple-mobile-web-app-title" content="TenBeltz">

<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
