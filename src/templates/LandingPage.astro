          class="method-graphic-shell mx-auto mt-12 w-full max-w-md rounded-2xl border border-pheromone-purple/25 bg-[#0B0122]/80 p-5 backdrop-blur-md shadow-[0_0_40px_rgba(96,43,182,0.2)] lg:mt-14 lg:max-w-xl lg:p-6"
          aria-hidden="true"
