---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import ServicesSection from '@/components/ServicesSection.astro';
import Contact from '@/components/Contact.astro';
import { getLangFromUrl } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const content = lang === 'en'
  ? {
      seoTitle: 'TenBeltz | AI engagement models for software companies',
      seoDescription: 'Explore the four ways TenBeltz works with SaaS teams and software consultancies on AI initiatives.',
    }
  : {
      seoTitle: 'TenBeltz | Modalidades de trabajo para proyectos de IA',
      seoDescription: 'Descubre las cuatro formas en las que TenBeltz trabaja con equipos SaaS y consultoras de software en proyectos de IA.',
    };
---

<Layout	
	title={content.seoTitle}
	description={content.seoDescription}
	canonical="https://tenbeltz.com/services"
>
	<Header />
	<main class="z-10 flex flex-col flex-1 overflow-x-hidden pt-24 lg:pt-28">
		<ServicesSection />
		<Contact />
	</main>
	<Footer />
</Layout>
