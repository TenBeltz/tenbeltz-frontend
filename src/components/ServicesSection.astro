---
import { ScrollReveal } from './ScrollReveal';
import { ReactComponent as DocumentsOutline } from '@/assets/icons/documents-outline.svg';
import { ReactComponent as PackageSearchOutline } from '@/assets/icons/package-search-outline.svg';
import { ReactComponent as SecureOutline } from '@/assets/icons/secure-outline.svg';
import { ReactComponent as TaskDoneOutline } from '@/assets/icons/task-done-outline.svg';
import { ReactComponent as ProcessOutline } from '@/assets/icons/process-outline.svg';
import { getLangFromUrl } from '@/i18n/utils';
import { getServicesCopy, type ServiceId } from '@/i18n/services';

const lang = getLangFromUrl(Astro.url);
const iconProps = { width: 24, height: 24, fill: 'none', stroke: '#E5C6F3', strokeWidth: 1.5 };
const copy = getServicesCopy(lang);

const serviceIcons: Record<ServiceId, typeof DocumentsOutline> = {
  'gap-analysis': DocumentsOutline,
  'foundations': PackageSearchOutline,
  'agent-mvp': ProcessOutline,
  'production-delivery': SecureOutline,
};
---

<section id="service-structure" class="text-white bg-grid">
  <div class="max-w-screen-xl px-4 py-20 mx-auto lg:px-16 lg:py-24">
    <ScrollReveal client:visible>
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.28em] text-pheromone-light/80">{copy.intro.tag}</p>
        <h2 class="mt-3 text-4xl font-bold lg:text-5xl">{copy.intro.title}</h2>
        <p class="mt-5 text-lg text-slate-300">{copy.intro.text}</p>
      </div>
    </ScrollReveal>

    <div class="grid grid-cols-1 gap-6 mt-10 lg:grid-cols-2">
      {copy.services.map((service, index) => {
        const Icon = serviceIcons[service.id];
        const spanFull = copy.services.length % 2 === 1 && index === copy.services.length - 1;
        return (
          <ScrollReveal client:visible delay={index * 90} className={spanFull ? 'lg:col-span-2' : undefined}>
            <article id={`service-${service.id}`} class="flex h-full scroll-mt-24 flex-col gap-5 rounded-2xl border border-pheromone-purple/25 bg-[#0B0122CC]/80 px-6 py-7 shadow-[0_0_25px_rgba(3,7,18,0.35)] backdrop-blur-sm">
              <div class="flex items-center justify-between gap-4">
                <span class="inline-flex rounded-full border border-pheromone-purple/40 bg-pheromone-purple/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-pheromone-light">
                  {service.tag}
                </span>
                <span class="flex h-11 w-11 items-center justify-center rounded-full bg-pheromone-purple/20">
                  <Icon {...iconProps} />
                </span>
              </div>
              <div class="flex flex-col gap-3">
                <h3 class="text-2xl font-semibold">{service.title}</h3>
                <p class="text-slate-300">{service.description}</p>
              </div>
              <div class="rounded-xl border border-white/8 bg-white/[0.03] px-4 py-4">
                <p class="text-sm font-semibold text-white">{service.fitTitle}</p>
                <p class="mt-2 text-sm text-slate-300">{service.fit}</p>
              </div>
              <ul class="flex flex-col gap-2 text-sm text-slate-300">
                {service.bullets.map((bullet) => <li>• {bullet}</li>)}
              </ul>
            </article>
          </ScrollReveal>
        );
      })}
    </div>

    <div class="grid grid-cols-1 gap-6 mt-16 lg:grid-cols-[1.1fr_0.9fr]">
      <ScrollReveal client:visible>
        <div class="rounded-2xl border border-pheromone-purple/20 bg-[#0B0122CC]/80 px-6 py-7 backdrop-blur-sm">
          <div class="flex items-center gap-3">
            <span class="flex h-11 w-11 items-center justify-center rounded-full bg-pheromone-purple/20">
              <TaskDoneOutline {...iconProps} />
            </span>
            <h3 class="text-2xl font-semibold">{copy.path.title}</h3>
          </div>
          <ul class="flex flex-col gap-3 mt-5 text-slate-300">
            {copy.path.items.map((item) => <li>• {item}</li>)}
          </ul>
        </div>
      </ScrollReveal>
      <ScrollReveal client:visible delay={120}>
        <div class="rounded-2xl border border-pheromone-purple/25 bg-gradient-to-br from-[#16002E] to-[#240044] px-6 py-7 backdrop-blur-sm">
          <div class="flex items-center gap-3">
            <span class="flex h-11 w-11 items-center justify-center rounded-full bg-pheromone-purple/20">
              <ProcessOutline width="24" height="24" fill="#E5C6F3" />
            </span>
            <h3 class="text-2xl font-semibold">{copy.cta.title}</h3>
          </div>
          <p class="mt-5 text-slate-300">{copy.cta.text}</p>
          <a href="#contact-section" class="inline-flex items-center justify-center mt-6 rounded-xl bg-gradient-to-r from-pheromone-purple to-blueberry-glaze px-6 py-3 text-base font-semibold text-white shadow-[0_20px_42px_rgba(96,43,182,0.34)] transition-transform duration-300 hover:-translate-y-0.5">
            {copy.cta.button}
          </a>
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>
