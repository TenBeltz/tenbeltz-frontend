              <p class="text-xl font-semibold text-white">{content.founder.title}</p>
              <p class="text-base text-slate-300">{content.founder.description}</p>
            </div>
            <span class="inline-flex items-center gap-x-2 whitespace-nowrap text-sm font-semibold text-pheromone-light transition-colors group-hover:text-white">
              {content.founder.cta}
              <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">&rarr;</span>
            </span>
          </a>
        </ScrollReveal>
      </div>
    </section>

    <Contact />
    <LandingPageMotion client:load />
  </main>
  <Footer />
