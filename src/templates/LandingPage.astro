              </div>
              <ul class="relative mt-8 flex flex-col gap-5">
                {content.fit.yes.map((item) => (
                  <li class="flex items-start gap-4">
                    <span aria-hidden="true" class="mt-1.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full border border-cold-heights/40 bg-cold-heights/10">
                      <svg width="10" height="10" viewBox="0 0 10 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M1.5 5.2 4 7.5 8.5 2.5" stroke="#79CAFF" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </span>
                    <p class="text-base leading-relaxed text-slate-200 lg:text-lg">{item}</p>
                  </li>
                ))}
              </ul>
            </div>
          </ScrollReveal>
          <ScrollReveal client:visible delay={120} className="lg:col-span-2">
            <div class="relative h-full overflow-hidden rounded-3xl border border-slate-700/50 bg-[#0A0116]/80 p-8 backdrop-blur-sm lg:p-10">
              <div class="relative flex items-center gap-3">
                <span class="inline-flex h-2 w-2 rounded-full bg-slate-500"></span>
                <span class="font-mono text-xs font-semibold uppercase tracking-[0.32em] text-slate-400">{content.fit.noTitle}</span>
              </div>
              <ul class="relative mt-8 flex flex-col gap-5">
                {content.fit.no.map((item) => (
                  <li class="flex items-start gap-4">
