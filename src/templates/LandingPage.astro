                      <span class="block h-px w-2 bg-slate-500"></span>
                    </span>
                    <p class="text-sm leading-relaxed text-slate-400 lg:text-base">{item}</p>
                  </li>
                ))}
              </ul>
            </div>
          </ScrollReveal>
        </div>
      </div>
